@{
    var activeRole = ViewBag.ActiveRole as string ?? "SuperAdmin";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - BuyZaar SuperAdmin</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/superadmin-dashboard.css"
          asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <div class="mobile-overlay" id="mobileOverlay"></div>

    <div class="dashboard-layout">

        <aside class="dashboard-sidebar" id="dashboardSidebar">

            <div class="sidebar-mobile-header">
                <div class="sidebar-mobile-brand">
                    <img src="~/images/icon_logo.png" alt="BuyZaar Logo" />

                    <div>
                        <strong>BuyZaar</strong>
                        <span>SuperAdmin Panel</span>
                    </div>
                </div>

                <button type="button"
                        class="sidebar-close-btn"
                        id="sidebarCloseBtn">
                    ✕
                </button>
            </div>

            <div class="sidebar-main">

                <div class="sidebar-logo">
                    <img src="~/images/icon_logo.png"
                         alt="BuyZaar Logo" />

                    <h5>BuyZaar</h5>
                    <span>SuperAdmin Panel</span>
                </div>

                <nav class="sidebar-nav">

                    <a asp-controller="SuperAdmin"
                       asp-action="Index"
                       class="sidebar-link @(currentAction == "Index" ? "active" : "")">
                        Dashboard
                    </a>

                    <div class="sidebar-group-title">
                        Admin Control
                    </div>

                    <a asp-controller="SuperAdmin"
                       asp-action="CreateAdmin"
                       class="sidebar-link @(currentAction == "CreateAdmin" ? "active" : "")">
                        Create Admin
                    </a>

                    <a asp-controller="SuperAdmin"
                       asp-action="Admins"
                       class="sidebar-link @(currentAction == "Admins" ? "active" : "")">
                        Manage Admins
                    </a>

                    <div class="sidebar-group-title">
                        Platform Users
                    </div>

                    <a asp-controller="SuperAdmin"
                       asp-action="Users"
                       class="sidebar-link @(currentAction == "Users" ? "active" : "")">
                        All Users
                    </a>

                    <a asp-controller="SuperAdmin"
                       asp-action="Sellers"
                       class="sidebar-link @(currentAction == "Sellers" ? "active" : "")">
                        Sellers
                    </a>

                    <a asp-controller="SuperAdmin"
                       asp-action="Riders"
                       class="sidebar-link @(currentAction == "Riders" ? "active" : "")">
                        Riders
                    </a>

                    <div class="sidebar-group-title">
                        Platform Monitoring
                    </div>

                    <a asp-controller="SuperAdmin"
                       asp-action="Products"
                       class="sidebar-link @(currentAction == "Products" ? "active" : "")">
                        Products
                    </a>

                    <a asp-controller="SuperAdmin"
                       asp-action="Orders"
                       class="sidebar-link @(currentAction == "Orders" ? "active" : "")">
                        Orders
                    </a>

                    <div class="sidebar-group-title">
                        Financial Oversight
                    </div>

                    <a asp-controller="SuperAdmin"
                       asp-action="Payments"
                       class="sidebar-link @(currentAction == "Payments" ? "active" : "")">
                        Payments
                    </a>

                    <a asp-controller="SuperAdmin"
                       asp-action="Payouts"
                       class="sidebar-link @(currentAction == "Payouts" ? "active" : "")">
                        Seller Settlements
                    </a>

                    <div class="sidebar-group-title">
                        System Oversight
                    </div>

                    <a asp-controller="SuperAdmin"
                       asp-action="Reports"
                       class="sidebar-link @(currentAction == "Reports" ? "active" : "")">
                        Reports
                    </a>

                    <a asp-controller="SuperAdmin"
                       asp-action="AuditLogs"
                       class="sidebar-link @(currentAction == "AuditLogs" ? "active" : "")">
                        Audit Logs
                    </a>

                    <a asp-controller="SuperAdmin"
                       asp-action="Settings"
                       class="sidebar-link @(currentAction == "Settings" ? "active" : "")">
                        System Settings
                    </a>

                </nav>
            </div>

            <div class="sidebar-account">
                <div class="sidebar-user">

                    <div class="sidebar-avatar">
                        @((User.Identity?.Name ?? "S").Substring(0, 1).ToUpper())
                    </div>

                    <div class="sidebar-user-info">
                        <div class="sidebar-user-name">
                            @User.Identity?.Name
                        </div>

                        <div class="sidebar-user-role">
                            @activeRole
                        </div>
                    </div>

                </div>

                <form asp-controller="Account"
                      asp-action="Logout"
                      method="post">

                    @Html.AntiForgeryToken()

                    <button type="submit"
                            class="sidebar-logout-btn">
                        Sign out
                    </button>

                </form>
            </div>
        </aside>

        <main class="dashboard-main">

            <div class="dashboard-topbar">

                <div class="dashboard-topbar-left">
                    <button type="button"
                            class="mobile-menu-btn"
                            id="mobileMenuBtn">
                        ☰
                    </button>

                    <div class="dashboard-topbar-title">
                        <h4>@ViewData["Title"]</h4>
                        <p>Manage BuyZaar system operations</p>
                    </div>
                </div>

                <div class="dashboard-topbar-actions">
                    <button class="notification-btn">
                        🔔
                        <span class="notification-badge">3</span>
                    </button>
                </div>

            </div>

            <div class="dashboard-content">
                @RenderBody()
            </div>

        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const sidebar = document.getElementById("dashboardSidebar");
        const menuBtn = document.getElementById("mobileMenuBtn");
        const closeBtn = document.getElementById("sidebarCloseBtn");
        const overlay = document.getElementById("mobileOverlay");

        function openSidebar() {
            sidebar?.classList.add("show");
            overlay?.classList.add("show");
            document.body.classList.add("sidebar-open");
        }

        function closeSidebar() {
            sidebar?.classList.remove("show");
            overlay?.classList.remove("show");
            document.body.classList.remove("sidebar-open");
        }

        menuBtn?.addEventListener("click", openSidebar);
        closeBtn?.addEventListener("click", closeSidebar);
        overlay?.addEventListener("click", closeSidebar);

        document.querySelectorAll(".sidebar-link").forEach(link => {
            link.addEventListener("click", () => {
                if (window.innerWidth <= 768) {
                    closeSidebar();
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>