@{
    var activeRole = ViewBag.ActiveRole as string ?? "";

    var isSeller = User.IsInRole("Seller");
    var isShopper = User.IsInRole("Shopper");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - BuyZaar</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <div class="dashboard-layout">

        <aside class="dashboard-sidebar">
            <div class="sidebar-main">

                <div class="sidebar-logo">
                    <img src="~/images/icon_logo.png" alt="BuyZaar Logo" />
                    <h5>BuyZaar</h5>
                    <span>@activeRole Panel</span>
                </div>

                <nav class="sidebar-nav">

                    @if (activeRole == "Seller")
                    {
                        <a asp-controller="Seller"
                           asp-action="Index"
                           class="sidebar-link">
                            Dashboard
                        </a>

                        <div class="sidebar-group-title">
                            Product Management
                        </div>

                        <a asp-controller="Seller"
                           asp-action="Products"
                           class="sidebar-link">
                            Manage Products
                        </a>

                        <a asp-controller="Seller"
                           asp-action="CreateProduct"
                           class="sidebar-link">
                            Add Product
                        </a>

                        <div class="sidebar-group-title">
                            Order Management
                        </div>

                        <a asp-controller="Seller"
                           asp-action="Orders"
                           class="sidebar-link">
                            Orders
                        </a>

                        <div class="sidebar-group-title">
                            Business
                        </div>

                        <a asp-controller="Seller"
                           asp-action="SalesRecords"
                           class="sidebar-link">
                            Sales Records
                        </a>

                        <a asp-controller="Seller"
                           asp-action="ShopProfile"
                           class="sidebar-link">
                            Shop Profile
                        </a>
                    }
                    else if (activeRole == "Shopper")
                    {
                        <a asp-controller="Shopper"
                           asp-action="BrowseProducts"
                           class="sidebar-link">
                            Home
                        </a>

                        <div class="sidebar-group-title">
                            Shopping
                        </div>

                        <a asp-controller="Shopper"
                           asp-action="MyCart"
                           class="sidebar-link">
                            My Cart
                        </a>

                        <a asp-controller="Shopper"
                           asp-action="MyOrders"
                           class="sidebar-link">
                            My Orders
                        </a>

                        <div class="sidebar-group-title">
                            Account
                        </div>

                        <a asp-controller="Shopper"
                           asp-action="Index"
                           class="sidebar-link">
                            Profile
                        </a>

                        @if (!isSeller)
                        {
                            <a asp-controller="Shopper"
                               asp-action="ApplySeller"
                               class="sidebar-link">
                                Apply as Seller
                            </a>
                        }
                    }

                </nav>
            </div>

            <div class="sidebar-account">

                <div class="sidebar-user">

                    <div class="sidebar-avatar">
                        @((User.Identity?.Name ?? "U")
                            .Substring(0, 1)
                            .ToUpper())
                    </div>

                    <div class="sidebar-user-info">
                        <div class="sidebar-user-name">
                            @User.Identity?.Name
                        </div>

                        <div class="sidebar-user-role">
                            @activeRole
                        </div>
                    </div>

                    <div class="dropdown ms-auto">
                        <button class="sidebar-settings-btn"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            ⚙
                        </button>

                        <ul class="dropdown-menu sidebar-settings-menu">
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Shopper"
                                   asp-action="Index">
                                    Profile
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" href="#">
                                    Settings
                                </a>
                            </li>

                            @if (activeRole == "Seller")
                            {
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Shopper"
                                       asp-action="BrowseProducts">
                                        Switch to Shopper
                                    </a>
                                </li>
                            }
                            else if (activeRole == "Shopper" && isSeller)
                            {
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Seller"
                                       asp-action="Index">
                                        Switch to Seller
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                </div>

                <form asp-controller="Account"
                      asp-action="Logout"
                      method="post"
                      class="sidebar-signout-form">

                    @Html.AntiForgeryToken()

                    <button type="submit"
                            class="sidebar-logout-btn">
                        Sign out
                    </button>

                </form>

            </div>
        </aside>

        <main class="dashboard-main">

            <div class="dashboard-topbar">

                <div class="dashboard-topbar-content">
                    @if (IsSectionDefined("TopbarContent"))
                    {
                        @RenderSection("TopbarContent", required: false)
                    }
                    else
                    {
                        <div>
                            <h4>@ViewData["Title"]</h4>
                            <p>Manage your BuyZaar @activeRole workspace</p>
                        </div>
                    }
                </div>

                <div class="dashboard-topbar-actions">
                    <div class="dropdown">
                        <button class="notification-btn"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false">
                            🔔
                            <span class="notification-badge">3</span>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end notification-dropdown">
                            <li class="dropdown-header">Notifications</li>

                            @if (activeRole == "Seller")
                            {
                                <li>
                                    <a class="dropdown-item" href="#">
                                        New order received
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="#">
                                        Low stock alert
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="#">
                                        Product listing updated
                                    </a>
                                </li>
                            }
                            else if (activeRole == "Shopper")
                            {
                                <li>
                                    <a class="dropdown-item" href="#">
                                        Order is being prepared
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="#">
                                        Cart item reminder
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="#">
                                        Seller application update
                                    </a>
                                </li>
                            }

                            <li>
                                <hr class="dropdown-divider" />
                            </li>

                            <li>
                                <a class="dropdown-item text-center" href="#">
                                    View All
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

            </div>

            <div class="dashboard-content">
                @RenderBody()
            </div>

        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>