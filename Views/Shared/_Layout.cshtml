<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BuyZaar</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        /* Styling the topbar */
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 30px;
            background-color: #ffffff;
            border-bottom: 1px solid #e5e7eb;
        }

        .sidebar-brand img {
            max-width: 180px;  /* Adjust logo size */
            height: auto;
        }

        .topbar .sidebar-link {
            font-size: 14px;
            color: #333;
            text-decoration: none;
        }

        .topbar .btn {
            font-size: 14px;
            padding: 8px 18px;
        }

        .footer-custom {
            background-color: #f9fafb;
            padding: 20px;
            text-align: center;
            font-size: 14px;
            color: #6b7280;
        }

        .footer-custom a {
            color: #6b7280;
            text-decoration: none;
            margin: 0 10px;
        }

        .footer-custom a:hover {
            color: #4338ca;
        }

        /* Ensure buttons are visible */
        .auth-buttons {
            display: inline-block; /* Ensure that the buttons are visible */
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="app-layout">
        <!-- Header (Topbar) -->
        <div class="topbar">
            <a href="#" class="sidebar-brand">
                <img src="~/images/text_logo.png" alt="BuyZaar Logo" class="logo" />
            </a>
            <div class="d-flex gap-4">
                <a class="sidebar-link" href="#">Home</a>
                <a class="sidebar-link" href="#">Privacy</a>
            </div>
            <div class="d-flex gap-2">
                <!-- Login/Register buttons only shown when user is not authenticated -->
                @if (!User.Identity.IsAuthenticated)
                {
                    <div class="auth-buttons">
                        <a class="btn btn-outline-primary" href="/Account/Login">Login</a>
                        <a class="btn btn-primary" href="/Account/Register">Register</a>
                    </div>
                }
                else
                {
                    <!-- For authenticated users: Show user name with dropdown -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                            Hello, @User.Identity.Name
                        </button>
                        <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                            @if (User.IsInRole("Shopper"))
                            {
                                <li><a class="dropdown-item" href="/Seller/Index">Switch to Seller</a></li>
                            }
                            @if (User.IsInRole("Seller"))
                            {
                                <li><a class="dropdown-item" href="/Shopper/Index">Switch to Shopper</a></li>
                            }
                            <li><a class="dropdown-item" href="/Account/Logout">Logout</a></li>
                        </ul>
                    </div>
                }
            </div>
        </div>

        <!-- Main Content Area -->
        <main class="page-content">
            @RenderBody()  <!-- This will render the content of your pages -->
        </main>

        <!-- Footer -->
        <footer class="footer-custom">
            <p>&copy; 2026 - BuyZaar</p>
            <div class="social-links">
                <a href="#">Facebook</a> | <a href="#">Twitter</a> | <a href="#">Instagram</a>
            </div>
        </footer>
    </div>

 <!-- Render JavaScript that is specific to the current page -->
    @RenderSection("Scripts", false)  <!-- This allows pages to inject page-specific JavaScript -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>