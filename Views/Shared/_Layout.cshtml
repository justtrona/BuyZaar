<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BuyZaar</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>
    <div class="app-layout">
<div class="topbar">
    <!-- Logo Section -->
    <a href="/" class="sidebar-brand d-flex align-items-center">
        <img src="~/images/text_logo.png" alt="BuyZaar Logo" class="logo" />
    </a>
    
    <!-- Navigation Links (Home, Privacy, etc.) -->
    <div class="d-flex gap-4">
        <a class="sidebar-link" href="#">Home</a>
        <a class="sidebar-link" href="#">Privacy</a>
    </div>
    
    <!-- Always Show Auth buttons (for testing purposes) -->
    <div class="d-flex gap-2" style="z-index: 9999;">
        <!-- Login/Register buttons always visible -->
        <div class="auth-buttons">
            <a class="btn btn-outline-primary" href="/Account/Login">Login</a>
            <a class="btn btn-primary" href="/Account/Register">Register</a>
        </div>
    </div>
</div>

        <!-- Main Content Area -->
        <main class="page-content">
            @RenderBody()  <!-- Content of the page will be injected here -->
        </main>

        <!-- Footer -->
        <footer class="footer-custom text-center py-4">
            <div class="container">
                <p>&copy; 2026 - BuyZaar</p>
                <div class="social-links">
                    <a href="#">Facebook</a> | <a href="#">Twitter</a> | <a href="#">Instagram</a>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>