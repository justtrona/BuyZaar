<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BuyZaar</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BuyZaar.styles.css" asp-append-version="true" />

    <style>
        body {
            background-color: #f5f7ff;
            margin: 0;
            font-family: Arial, sans-serif;
        }

        .app-layout {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 260px;
            background: #ffffff;
            border-right: 1px solid #e5e7eb;
            padding: 24px 18px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            box-shadow: 2px 0 12px rgba(0, 0, 0, 0.03);
        }

        .sidebar-brand {
            font-size: 1.8rem;
            font-weight: 700;
            color: #4338ca;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 24px;
        }

        .sidebar-section-title {
            font-size: 0.8rem;
            font-weight: 700;
            color: #9ca3af;
            text-transform: uppercase;
            margin: 20px 12px 8px;
        }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .sidebar-link {
            display: block;
            text-decoration: none;
            color: #1f2937;
            padding: 12px 14px;
            border-radius: 12px;
            transition: all 0.2s ease;
            font-weight: 500;
        }

        .sidebar-link:hover {
            background: #eef2ff;
            color: #4338ca;
        }

        .main-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .topbar {
            background: #ffffff;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .topbar-title {
            font-size: 1rem;
            font-weight: 600;
            color: #374151;
        }

        .user-menu-btn {
            border-radius: 12px;
            padding: 8px 14px;
            font-weight: 500;
            border: 1px solid #e5e7eb;
            background: #fff;
            color: #111827;
        }

        .dropdown-menu {
            border-radius: 14px;
            border: none;
            padding: 10px 0;
            min-width: 220px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
        }

        .dropdown-item {
            padding: 10px 16px;
            font-size: 0.95rem;
        }

        .page-content {
            flex: 1;
            padding: 24px;
        }

        .content-card {
            background: #f2f5ff;
            border-radius: 18px;
            padding: 24px;
            min-height: calc(100vh - 180px);
        }

        .footer-custom {
            background: transparent;
            padding: 12px 24px 20px;
            color: #6b7280;
            font-size: 0.95rem;
        }

        @@media (max-width: 991.98px) {
            .app-layout {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                border-right: none;
                border-bottom: 1px solid #e5e7eb;
            }

            .content-card {
                min-height: auto;
            }
        }
    </style>
</head>
<body>
    <div class="app-layout">
       <aside class="sidebar">
    <div>
        <a class="sidebar-brand" asp-controller="Home" asp-action="Index">BuyZaar</a>

        <div class="sidebar-section-title">Main</div>
        <nav class="sidebar-nav">
            <a class="sidebar-link" asp-controller="Home" asp-action="Index">Home</a>
            <a class="sidebar-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </nav>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <!-- Shopper Sidebar -->
            @if (User.IsInRole("Shopper") && !User.IsInRole("Seller"))
            {
                <div class="sidebar-section-title">Shopper</div>
                <nav class="sidebar-nav">
                    <a class="sidebar-link" asp-controller="Shopper" asp-action="Index">Dashboard</a>
                    <a class="sidebar-link">My Orders</a>
                    <a class="sidebar-link">Cart</a>
                </nav>
            }

            <!-- Seller Sidebar -->
            @if (User.IsInRole("Seller"))
            {
                <div class="sidebar-section-title">Seller</div>
                <nav class="sidebar-nav">
                    <a class="sidebar-link" asp-controller="Seller" asp-action="Index">Dashboard</a>
                    <a class="sidebar-link">Products</a>
                    <a class="sidebar-link">Orders</a>
                </nav>
            }
        }
    </div>
</aside>

        <!-- Main -->
        <div class="main-area">
            <div class="topbar">
                <div class="topbar-title">@ViewData["Title"]</div>

                <div>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown">
                            <button class="btn user-menu-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Hello, @User.Identity.Name
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <span class="dropdown-item-text fw-semibold text-muted">Account Menu</span>
                                </li>

                                @if (User.IsInRole("Shopper"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Shopper" asp-action="Index">Switch to Shopper</a>
                                    </li>
                                }

                                @if (User.IsInRole("Seller"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Seller" asp-action="Index">Switch to Seller</a>
                                    </li>
                                }

                                @if (User.IsInRole("Admin"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="Index">Switch to Admin</a>
                                    </li>
                                }

                                @if (User.IsInRole("SuperAdmin"))
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="SuperAdmin" asp-action="Index">Switch to SuperAdmin</a>
                                    </li>
                                }

                                <li><hr class="dropdown-divider" /></li>

                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Login">Login</a>
                            <a class="btn btn-primary" asp-controller="Account" asp-action="Register">Register</a>
                        </div>
                    }
                </div>
            </div>

            <main class="page-content">
                <div class="content-card">
                    @RenderBody()
                </div>
            </main>

            <footer class="footer-custom">
                &copy; 2026 - BuyZaar -
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>