@using BuyZaar.Models
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager

@{
    var activeRole = ViewBag.ActiveRole as string ?? "Rider";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    var currentUser = await UserManager.GetUserAsync(User);

    var riderDisplayName = !string.IsNullOrWhiteSpace(currentUser?.FullName)
        ? currentUser.FullName
        : "Rider";

    var avatarLetter = riderDisplayName.Substring(0, 1).ToUpper();

    var pageSubtitle = currentAction switch
    {
        "Index" => "Overview of your rider dashboard",
        "AssignedOrders" => "Review delivery tasks assigned to you",
        "AvailableTasks" => "Accept available delivery tasks",
        "ActiveDeliveries" => "Manage deliveries currently in progress",
        "DeliveryScope" => "View your delivery coverage and guidelines",
        "DeliveryHistory" => "Review completed and returned deliveries",
        "Profile" => "Manage your rider account information",
        _ => "Manage assigned deliveries and rider activities"
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - BuyZaar Rider</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/rider-dashboard.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <div class="rider-mobile-overlay" id="riderMobileOverlay"></div>

    <div class="rider-layout">

        <aside class="rider-sidebar" id="riderSidebar">

            <div class="rider-sidebar-mobile-header">
                <div class="rider-mobile-brand">
                    <img src="~/images/icon_logo.png" alt="BuyZaar Logo" />

                    <div>
                        <strong>BuyZaar</strong>
                        <span>Rider Panel</span>
                    </div>
                </div>

                <button type="button"
                        class="rider-sidebar-close"
                        onclick="closeRiderSidebar()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="rider-sidebar-main">

                <div class="rider-logo">
                    <img src="~/images/icon_logo.png"
                         alt="BuyZaar Logo" />

                    <h5>BuyZaar</h5>
                    <span>Rider Panel</span>
                </div>

                <nav class="rider-nav">

                    <a asp-controller="Rider"
                       asp-action="Index"
                       class="@(currentAction == "Index" ? "active" : "")">
                        <i class="fa-solid fa-house"></i>
                        <span>Dashboard</span>
                    </a>

                    <div class="rider-nav-group-title">
                        Delivery Tasks
                    </div>

                    <a asp-controller="Rider"
                       asp-action="AssignedOrders"
                       class="@(currentAction == "AssignedOrders" ? "active" : "")">
                        <i class="fa-solid fa-box"></i>
                        <span>Assigned Orders</span>
                    </a>

                    <a asp-controller="Rider"
                       asp-action="ActiveDeliveries"
                       class="@(currentAction == "ActiveDeliveries" ? "active" : "")">
                        <i class="fa-solid fa-truck-fast"></i>
                        <span>Active Deliveries</span>
                    </a>

                    <div class="rider-nav-group-title">
                        Monitoring
                    </div>

                    <a asp-controller="Rider"
                       asp-action="DeliveryScope"
                       class="@(currentAction == "DeliveryScope" ? "active" : "")">
                        <i class="fa-solid fa-location-dot"></i>
                        <span>Delivery Scope</span>
                    </a>

                    <a asp-controller="Rider"
                       asp-action="DeliveryHistory"
                       class="@(currentAction == "DeliveryHistory" ? "active" : "")">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                        <span>Delivery History</span>
                    </a>

                    <div class="rider-nav-group-title">
                        Account
                    </div>

                    <a asp-controller="Rider"
                       asp-action="Profile"
                       class="@(currentAction == "Profile" ? "active" : "")">
                        <i class="fa-solid fa-user"></i>
                        <span>Profile</span>
                    </a>

                </nav>

            </div>

            <div class="rider-account">

                <div class="rider-user">

                    <div class="rider-avatar">
                        @avatarLetter
                    </div>

                    <div class="rider-user-info">
                        <div class="rider-name">
                            @riderDisplayName
                        </div>

                        <div class="rider-role">
                            @activeRole
                        </div>
                    </div>

                </div>

                <form asp-controller="Account"
                      asp-action="Logout"
                      method="post">

                    @Html.AntiForgeryToken()

                    <button type="submit"
                            class="rider-logout-btn">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        Sign out
                    </button>

                </form>

            </div>

        </aside>

        <main class="rider-main">

            <div class="rider-topbar">

                <div class="rider-topbar-left">
                    <button type="button"
                            class="rider-mobile-menu-btn"
                            onclick="openRiderSidebar()">
                        <i class="fa-solid fa-bars"></i>
                    </button>

                    <div class="rider-topbar-title">
                        <h4>@ViewData["Title"]</h4>
                        <p>@pageSubtitle</p>
                    </div>
                </div>

                <div class="rider-topbar-actions">
                    <button class="rider-notification-btn">
                        <i class="fa-solid fa-bell"></i>
                        <span>0</span>
                    </button>
                </div>

            </div>

            <div class="rider-content">
                @RenderBody()
            </div>

        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function openRiderSidebar() {
            const sidebar = document.getElementById("riderSidebar");
            const overlay = document.getElementById("riderMobileOverlay");

            sidebar?.classList.add("show");
            overlay?.classList.add("show");
            document.body.classList.add("rider-sidebar-open");
        }

        function closeRiderSidebar() {
            const sidebar = document.getElementById("riderSidebar");
            const overlay = document.getElementById("riderMobileOverlay");

            sidebar?.classList.remove("show");
            overlay?.classList.remove("show");
            document.body.classList.remove("rider-sidebar-open");
        }

        document.addEventListener("DOMContentLoaded", function () {
            const overlay = document.getElementById("riderMobileOverlay");

            overlay?.addEventListener("click", closeRiderSidebar);

            document.querySelectorAll(".rider-nav a").forEach(function (link) {
                link.addEventListener("click", function () {
                    if (window.innerWidth <= 768) {
                        closeRiderSidebar();
                    }
                });
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>