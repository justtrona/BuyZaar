<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BuyZaar</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        /* Styling the sidebar */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100%;
            width: 250px;
            background-color: #f8f9fa;
            padding: 20px;
            border-right: 1px solid #ddd;
        }

        .sidebar-nav a {
            text-decoration: none;
            color: #495057;
            display: block;
            padding: 10px 15px;
            border-radius: 5px;
            margin-bottom: 10px;
            transition: background-color 0.3s;
        }

        .sidebar-nav a:hover {
            background-color: #e9ecef;
            color: #007bff;
        }

        /* Main content area */
        .main-content {
            margin-left: 250px;
            padding: 30px;
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            padding: 15px;
            background-color: #ffffff;
            border-bottom: 1px solid #ddd;
        }

        .dropdown-menu {
            width: 200px;
        }

        .dropdown-menu a {
            font-size: 14px;
        }

        .role-badge {
            background-color: #007bff;
            color: #fff;
            padding: 5px 10px;
            border-radius: 20px;
        }
    </style>
</head>
<body>
    <div class="app-layout">
        <!-- Sidebar for Seller -->
        <aside class="sidebar">
            <div>
                <a class="sidebar-brand" href="#">BuyZaar</a>
                <nav class="sidebar-nav">
                    <a href="/Seller/Index">Dashboard</a>
                    <a href="/Seller/Products">Products</a>
                    <a href="/Seller/Orders">Orders</a>
                    <a href="/Seller/Profile">Shop Profile</a>
                </nav>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="main-content">
            <!-- Topbar (User Info and Role Switch) -->
            <div class="topbar">
                <div class="d-flex align-items-center">
                    <span>Hello, @User.Identity?.Name</span>

                    <!-- Dropdown for switching roles and logging out -->
                    <div class="dropdown ml-4">
                        <button class="btn btn-sm btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                            Switch Role
                        </button>
                        <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                            @if (User.IsInRole("Shopper"))
                            {
                                <li><a class="dropdown-item" href="/Seller/Index">Switch to Seller</a></li>
                            }
                            @if (User.IsInRole("Seller"))
                            {
                                <li><a class="dropdown-item" href="/Shopper/Index">Switch to Shopper</a></li>
                            }
                            <li><a class="dropdown-item" href="/Account/Logout">Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Dashboard Content (Hero, Stats, Quick Actions, Activity) -->
            @RenderBody()  <!-- This will render the content of your pages -->
        </div>
    </div>

<!-- Render JavaScript that is specific to the current page -->
    @RenderSection("Scripts", false)  <!-- This allows pages to inject page-specific JavaScript -->
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>