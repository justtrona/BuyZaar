@{
    ViewData["Title"] = "Reset Link Sent";
}

<link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<div class="login-page">
    <div class="login-bg-circle left"></div>
    <div class="login-bg-circle right"></div>
    <div class="login-dots dots-left"></div>
    <div class="login-dots dots-right"></div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5">

                <div class="login-card text-center">

                    <div class="login-logo-wrap">
                        <img src="~/images/icon_logo.png" class="login-logo" alt="BuyZaar Logo" />
                    </div>

                    <div class="feature-icon mx-auto mb-3">
                        <i class="bi bi-envelope-check"></i>
                    </div>

                    <h2>Check Your Email</h2>

                    <p class="login-subtitle">
                        If the email exists in our system, a password reset link has been sent.
                    </p>

                    <a asp-action="Login" class="login-btn text-decoration-none">
                        Back to Login
                    </a>

                </div>

            </div>
        </div>
    </div>
</div>