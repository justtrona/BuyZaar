@{
    ViewData["Title"] = "Verify Your Email";
    var email = ViewBag.Email as string;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5 text-center">
                    <h2 class="fw-bold mb-3">Verify Your Email First</h2>
                    <p class="text-muted mb-3">
                        Your Buyzaar account has been created successfully.
                    </p>
                    <p class="mb-3">
                        We sent a verification link to:
                    </p>
                    <p class="fw-semibold text-primary">@email</p>
                    <p class="text-muted mt-3">
                        Please check your inbox and click the verification link before logging in.
                    </p>
                    <p class="text-muted">
                        If you do not see the email, check your spam folder.
                    </p>

                    <div class="mt-4">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary px-4">
                            Go to Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>