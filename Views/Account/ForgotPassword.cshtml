@model BuyZaar.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<div class="login-page">
    <div class="login-bg-circle left"></div>
    <div class="login-bg-circle right"></div>
    <div class="login-dots dots-left"></div>
    <div class="login-dots dots-right"></div>

    <div class="container">
        <div class="row align-items-center justify-content-center g-5">

            <div class="col-lg-6">
                <div class="login-brand-side">
                    <div class="brand-badge">Account Recovery</div>

                    <h1>
                        Reset your
                        <span>password.</span>
                    </h1>

                    <p>
                        Enter your registered email address and we’ll send you
                        a secure link to create a new password.
                    </p>

                    <div class="brand-features">
                        <div class="brand-feature-card">
                            <div class="feature-icon">
                                <i class="bi bi-shield-lock"></i>
                            </div>
                            <div>
                                <strong>Secure Reset</strong>
                                <span>Your password reset link is protected</span>
                            </div>
                        </div>

                        <div class="brand-feature-card">
                            <div class="feature-icon">
                                <i class="bi bi-envelope-check"></i>
                            </div>
                            <div>
                                <strong>Email Verification</strong>
                                <span>Reset link will be sent to your email</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="login-card">

                    <div class="login-logo-wrap">
                        <img src="~/images/icon_logo.png" class="login-logo" alt="BuyZaar Logo" />
                    </div>

                    <h2>Forgot Password</h2>

                    <p class="login-subtitle">
                        Enter your email to receive a password reset link.
                    </p>

                    @if (TempData["ForgotPasswordMessage"] != null)
                    {
                        <div class="alert alert-success small">
                            @TempData["ForgotPasswordMessage"]
                        </div>
                    }

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="modern-input-group">
                            <span>
                                <i class="bi bi-envelope"></i>
                            </span>

                            <input asp-for="Email"
                                   class="modern-input"
                                   placeholder="Enter your email address" />
                        </div>

                        <span asp-validation-for="Email" class="text-danger small d-block mb-3"></span>

                        <button type="submit" class="login-btn">
                            Send Reset Link
                        </button>

                        <div class="login-divider">
                            <span>OR</span>
                        </div>

                        <div class="register-text">
                            Remember your password?
                            <a asp-action="Login">Back to Login</a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}