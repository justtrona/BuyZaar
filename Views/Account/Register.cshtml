@model BuyZaar.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="container py-5">
    <div class="row align-items-center justify-content-center">

        <!-- LEFT: LOGO -->
        <div class="col-md-6 text-center mb-4">
            <img src="~/images/logo.png" style="max-width: 300px;" />
            <h2 class="brand-title mt-3">BuyZaar</h2>
            <p class="brand-accent">Shop the Future Today</p>
        </div>

        <!-- RIGHT: FORM -->
        <div class="col-md-5">
            <div class="card shadow-lg p-4">
                <h3 class="text-center mb-4">Create Account</h3>

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <input asp-for="FullName" class="form-control form-control-lg" placeholder="Full Name" />
                    </div>

                    <div class="mb-3">
                        <input asp-for="Email" class="form-control form-control-lg" placeholder="Email" />
                    </div>

                    <div class="mb-3">
                        <input asp-for="UserName" class="form-control form-control-lg" placeholder="Username" />
                    </div>

                    <div class="mb-3">
                        <input asp-for="Password" class="form-control form-control-lg" placeholder="Password" />
                    </div>

                    <div class="mb-3">
                        <input asp-for="ConfirmPassword" class="form-control form-control-lg" placeholder="Confirm Password" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        Register
                    </button>

                    <div class="text-center mt-3">
                        <span>Already have an account?</span>
                        <a asp-action="Login">Login</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>