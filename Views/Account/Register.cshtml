@model BuyZaar.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<link rel="stylesheet" href="~/css/register.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<div class="container py-5">
    <div class="row align-items-center justify-content-center">

        <!-- LEFT: BRAND -->
        <div class="col-md-6 text-center mb-4">
            <img src="~/images/icon_logo.png" class="brand-logo" />
            <h2 class="brand-title mt-3">BuyZaar</h2>
            <p class="brand-accent">Shop the Future Today</p>
        </div>

        <!-- RIGHT: FORM -->
        <div class="col-md-5">
            <div class="card register-card p-4">
                <h3 class="text-center mb-4">Create Account</h3>

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <!-- Full Name -->
                    <div class="mb-3 input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input asp-for="FullName" class="form-control form-control-lg" placeholder="Full Name" />
                    </div>

                    <!-- Email -->
                    <div class="mb-3 input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control form-control-lg" placeholder="Email" />
                    </div>

                    <!-- Username -->
                    <div class="mb-3 input-group">
                        <span class="input-group-text"><i class="bi bi-person-badge"></i></span>
                        <input asp-for="UserName" class="form-control form-control-lg" placeholder="Username" />
                    </div>

                    <!-- Password -->
                    <div class="mb-3 input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" type="password" id="passwordField" class="form-control form-control-lg" placeholder="Password" />
                        <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('passwordField', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-3 input-group">
                        <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                        <input asp-for="ConfirmPassword" type="password" id="confirmPasswordField" class="form-control form-control-lg" placeholder="Confirm Password" />
                        <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('confirmPasswordField', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        Register
                    </button>

                    <!-- Divider -->
                    <div class="divider my-4">
                        <hr />
                        <span>OR</span>
                    </div>

                    <!-- Login -->
                    <div class="text-center">
                        <span>Already have an account?</span>
                        <a asp-action="Login" class="fw-bold text-decoration-none">Login</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

<script>
    function togglePassword(fieldId, btn) {
        const field = document.getElementById(fieldId);
        const icon = btn.querySelector("i");

        if (field.type === "password") {
            field.type = "text";
            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");
        } else {
            field.type = "password";
            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        }
    }
</script>