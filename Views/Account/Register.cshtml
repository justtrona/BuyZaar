@model BuyZaar.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<link rel="stylesheet" href="~/css/register.css" asp-append-version="true" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<div class="register-page">

    <!-- BACKGROUND -->
    <div class="register-bg-circle left"></div>
    <div class="register-bg-circle right"></div>

    <div class="register-dots dots-left"></div>
    <div class="register-dots dots-right"></div>

    <div class="container">
        <div class="row align-items-center justify-content-center g-5">

            <!-- LEFT SIDE -->
            <div class="col-lg-6">

                <div class="register-brand-side">

                    <div class="brand-badge">
                        Join the BuyZaar marketplace
                    </div>

                    <h1>
                        Start your shopping
                        <span>journey today.</span>
                    </h1>

                    <p>
                        Create your BuyZaar account and discover trending
                        products, trusted sellers, and exclusive deals.
                    </p>

                    <div class="brand-features">

                        <div class="brand-feature-card">
                            <div class="feature-icon">
                                <i class="bi bi-shop"></i>
                            </div>

                            <div>
                                <strong>Trusted Marketplace</strong>
                                <span>Safe and reliable online shopping</span>
                            </div>
                        </div>

                        <div class="brand-feature-card">
                            <div class="feature-icon">
                                <i class="bi bi-lightning-charge"></i>
                            </div>

                            <div>
                                <strong>Fast Experience</strong>
                                <span>Modern and smooth buying experience</span>
                            </div>
                        </div>

                        <div class="brand-feature-card">
                            <div class="feature-icon">
                                <i class="bi bi-stars"></i>
                            </div>

                            <div>
                                <strong>Exclusive Deals</strong>
                                <span>Get access to trending products</span>
                            </div>
                        </div>

                    </div>

                </div>

            </div>

            <!-- RIGHT SIDE -->
            <div class="col-lg-5">

                <div class="register-card">

                    <div class="register-logo-wrap">
                        <img src="~/images/icon_logo.png" class="register-logo" />
                    </div>

                    <h2>Create Account</h2>

                    <p class="register-subtitle">
                        Join BuyZaar and start exploring today.
                    </p>

                    <form asp-action="Register" method="post">

                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="All"
                             class="text-danger small mb-3"></div>

                        <!-- FULL NAME -->
                        <div class="modern-input-group">
                            <span>
                                <i class="bi bi-person"></i>
                            </span>

                            <input asp-for="FullName"
                                   class="modern-input"
                                   placeholder="Full Name" />
                        </div>

                        <!-- EMAIL -->
                        <div class="modern-input-group">
                            <span>
                                <i class="bi bi-envelope"></i>
                            </span>

                            <input asp-for="Email"
                                   class="modern-input"
                                   placeholder="Email Address" />
                        </div>

                        <!-- USERNAME -->
                        <div class="modern-input-group">
                            <span>
                                <i class="bi bi-person-badge"></i>
                            </span>

                            <input asp-for="UserName"
                                   class="modern-input"
                                   placeholder="Username" />
                        </div>

                        <!-- PASSWORD -->
                        <div class="modern-input-group">
                            <span>
                                <i class="bi bi-lock"></i>
                            </span>

                            <input asp-for="Password"
                                   type="password"
                                   id="passwordField"
                                   class="modern-input"
                                   placeholder="Password" />

                            <button type="button"
                                    class="password-toggle"
                                    onclick="togglePassword('passwordField', this)">

                                <i class="bi bi-eye"></i>
                            </button>
                        </div>

                        <!-- CONFIRM PASSWORD -->
                        <div class="modern-input-group">
                            <span>
                                <i class="bi bi-lock-fill"></i>
                            </span>

                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   id="confirmPasswordField"
                                   class="modern-input"
                                   placeholder="Confirm Password" />

                            <button type="button"
                                    class="password-toggle"
                                    onclick="togglePassword('confirmPasswordField', this)">

                                <i class="bi bi-eye"></i>
                            </button>
                        </div>

                        <!-- BUTTON -->
                        <button type="submit" class="register-btn">
                            Create BuyZaar Account
                        </button>

                        <!-- DIVIDER -->
                        <div class="register-divider">
                            <span>OR</span>
                        </div>

                        <!-- LOGIN -->
                        <div class="login-text">
                            Already have an account?
                            <a asp-action="Login">Login</a>
                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>
</div>

<script>
    function togglePassword(fieldId, btn) {

        const field = document.getElementById(fieldId);
        const icon = btn.querySelector("i");

        if (field.type === "password") {

            field.type = "text";

            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");

        } else {

            field.type = "password";

            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        }
    }
</script>