@model BuyZaar.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<link rel="stylesheet" href="~/css/login.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<div class="container py-5">
    <div class="row align-items-center justify-content-center">

        <!-- LEFT: BRAND -->
        <div class="col-md-6 text-center mb-4">
            <img src="~/images/icon_logo.png" class="brand-logo" />
            <h2 class="brand-title mt-3">BuyZaar</h2>
            <p class="brand-accent">Shop the Future Today</p>
        </div>

        <!-- RIGHT: LOGIN -->
        <div class="col-md-5">
            <div class="card login-card p-4">
                <h3 class="text-center mb-4">Welcome Back</h3>

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <!-- Email -->
                    <div class="mb-3 input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control form-control-lg" placeholder="Email" />
                    </div>

                    <!-- Password -->
                    <div class="mb-3 input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" type="password" id="loginPassword" class="form-control form-control-lg" placeholder="Password" />
                        <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('loginPassword', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>

                    <!-- Remember Me -->
                    <div class="form-check mb-3">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        Login
                    </button>

                    <!-- Divider -->
                    <div class="divider my-4">
                        <hr />
                        <span>OR</span>
                    </div>

                    <!-- Register -->
                    <div class="text-center">
                        <span>Don't have an account?</span>
                        <a asp-action="Register" class="auth-link">Register</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

<script>
    function togglePassword(fieldId, btn) {
        const field = document.getElementById(fieldId);
        const icon = btn.querySelector("i");

        if (field.type === "password") {
            field.type = "text";
            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");
        } else {
            field.type = "password";
            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        }
    }
</script>