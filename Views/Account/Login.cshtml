@model BuyZaar.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<div class="login-page">

    <!-- BACKGROUND DECOR -->
    <div class="login-bg-circle left"></div>
    <div class="login-bg-circle right"></div>

    <div class="login-dots dots-left"></div>
    <div class="login-dots dots-right"></div>

    <div class="container">
        <div class="row align-items-center justify-content-center g-5">

            <!-- LEFT SIDE -->
            <div class="col-lg-6">

                <div class="login-brand-side">

                    <div class="brand-badge">
                        Trusted local marketplace
                    </div>

                    <h1>
                        Welcome back to
                        <span>BuyZaar.</span>
                    </h1>

                    <p>
                        Continue discovering products, deals, and trusted
                        local sellers in one modern marketplace experience.
                    </p>

                    <div class="brand-features">

                        <div class="brand-feature-card">
                            <div class="feature-icon">
                                <i class="bi bi-shield-check"></i>
                            </div>

                            <div>
                                <strong>Safe Shopping</strong>
                                <span>Verified sellers & trusted products</span>
                            </div>
                        </div>

                        <div class="brand-feature-card">
                            <div class="feature-icon">
                                <i class="bi bi-tags"></i>
                            </div>

                            <div>
                                <strong>Best Deals</strong>
                                <span>Affordable marketplace finds</span>
                            </div>
                        </div>

                        <div class="brand-feature-card">
                            <div class="feature-icon">
                                <i class="bi bi-bag-check"></i>
                            </div>

                            <div>
                                <strong>Easy Experience</strong>
                                <span>Simple shopping for everyone</span>
                            </div>
                        </div>

                    </div>

                </div>

            </div>

            <!-- RIGHT SIDE -->
            <div class="col-lg-5">

                <div class="login-card">

                    <div class="login-logo-wrap">
                        <img src="~/images/icon_logo.png" class="login-logo" />
                    </div>

                    <h2>Welcome Back</h2>

                    <p class="login-subtitle">
                        Login to continue shopping with BuyZaar.
                    </p>

                    <form asp-action="Login" method="post">

                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                        <!-- EMAIL -->
                        <div class="modern-input-group">
                            <span>
                                <i class="bi bi-envelope"></i>
                            </span>

                            <input asp-for="Email"
                                   class="modern-input"
                                   placeholder="Enter your email" />
                        </div>

                        <!-- PASSWORD -->
                        <div class="modern-input-group">
                            <span>
                                <i class="bi bi-lock"></i>
                            </span>

                            <input asp-for="Password"
                                   type="password"
                                   id="loginPassword"
                                   class="modern-input"
                                   placeholder="Enter your password" />

                            <button type="button"
                                    class="password-toggle"
                                    onclick="togglePassword('loginPassword', this)">

                                <i class="bi bi-eye"></i>
                            </button>
                        </div>

                        <!-- OPTIONS -->
                        <div class="login-options">

                            <div class="form-check">
                                <input asp-for="RememberMe"
                                       class="form-check-input" />

                                <label asp-for="RememberMe"
                                       class="form-check-label">
                                    Remember me
                                </label>
                            </div>

                            <a href="#" class="forgot-link">
                                Forgot Password?
                            </a>

                        </div>

                        <!-- BUTTON -->
                        <button type="submit" class="login-btn">
                            Login to BuyZaar
                        </button>

                        <!-- DIVIDER -->
                        <div class="login-divider">
                            <span>OR</span>
                        </div>

                        <!-- REGISTER -->
                        <div class="register-text">
                            Don't have an account?
                            <a asp-action="Register">Create account</a>
                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>
</div>

<script>
    function togglePassword(fieldId, btn) {

        const field = document.getElementById(fieldId);
        const icon = btn.querySelector("i");

        if (field.type === "password") {

            field.type = "text";

            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");

        } else {

            field.type = "password";

            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        }
    }
</script>