@model BuyZaar.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<div class="login-page">
    <div class="login-bg-circle left"></div>
    <div class="login-bg-circle right"></div>
    <div class="login-dots dots-left"></div>
    <div class="login-dots dots-right"></div>

    <div class="container">
        <div class="row align-items-center justify-content-center g-5">

            <div class="col-lg-6">
                <div class="login-brand-side">
                    <div class="brand-badge">Create New Password</div>

                    <h1>
                        Set a stronger
                        <span>password.</span>
                    </h1>

                    <p>
                        Use a secure password with uppercase, lowercase,
                        number, and special character.
                    </p>

                    <div class="brand-features">
                        <div class="brand-feature-card">
                            <div class="feature-icon">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <div>
                                <strong>Strong Security</strong>
                                <span>Protect your BuyZaar account</span>
                            </div>
                        </div>

                        <div class="brand-feature-card">
                            <div class="feature-icon">
                                <i class="bi bi-key"></i>
                            </div>
                            <div>
                                <strong>New Access</strong>
                                <span>Login again after resetting</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="login-card">

                    <div class="login-logo-wrap">
                        <img src="~/images/icon_logo.png" class="login-logo" alt="BuyZaar Logo" />
                    </div>

                    <h2>Reset Password</h2>

                    <p class="login-subtitle">
                        Enter your new password below.
                    </p>

                    <form asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <input asp-for="Email" type="hidden" />
                        <input asp-for="Token" type="hidden" />

                        <div class="modern-input-group">
                            <span>
                                <i class="bi bi-lock"></i>
                            </span>

                            <input asp-for="Password"
                                   type="password"
                                   id="resetPassword"
                                   class="modern-input"
                                   placeholder="New password" />

                            <button type="button"
                                    class="password-toggle"
                                    onclick="togglePassword('resetPassword', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>

                        <span asp-validation-for="Password" class="text-danger small d-block mb-2"></span>

                        <div class="password-rules mb-3">
                            Password must contain at least 8 characters, uppercase, lowercase, number, and special character.
                        </div>

                        <div class="modern-input-group">
                            <span>
                                <i class="bi bi-lock-fill"></i>
                            </span>

                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   id="confirmResetPassword"
                                   class="modern-input"
                                   placeholder="Confirm new password" />

                            <button type="button"
                                    class="password-toggle"
                                    onclick="togglePassword('confirmResetPassword', this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>

                        <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mb-3"></span>

                        <button type="submit" class="login-btn">
                            Reset Password
                        </button>

                        <div class="login-divider">
                            <span>OR</span>
                        </div>

                        <div class="register-text">
                            Remember your password?
                            <a asp-action="Login">Back to Login</a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword(fieldId, btn) {
            const field = document.getElementById(fieldId);
            const icon = btn.querySelector("i");

            if (field.type === "password") {
                field.type = "text";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            } else {
                field.type = "password";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            }
        }
    </script>
}