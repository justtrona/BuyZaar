@model BuyZaar.ViewModels.SellerApplicationViewModel

@{
    Layout = "_DashboardLayout";
    ViewBag.ActiveRole = "Shopper";
    ViewData["Title"] = "Apply as Seller";
}

<link rel="stylesheet" href="~/css/applyseller.css" asp-append-version="true" />

<div class="seller-apply-page">

    <div class="seller-apply-header">
        <div>
            <span class="seller-apply-badge">Seller Application</span>
            <h1>Start Selling on BuyZaar</h1>
            <p>
                Fill out your shop details below. Your application will be reviewed by an admin before your seller account is activated.
            </p>
        </div>

        <a asp-controller="Shopper"
           asp-action="Index"
           class="back-profile-btn">
            Back to Profile
        </a>
    </div>

    <div class="seller-apply-grid">

        <div class="seller-info-card">
            <h2>Before you apply</h2>

            <div class="info-step">
                <span>1</span>
                <div>
                    <strong>Complete your seller details</strong>
                    <p>Provide your full name, shop name, contact number, business address, and verification documents.</p>
                </div>
            </div>

            <div class="info-step">
                <span>2</span>
                <div>
                    <strong>Upload verification documents</strong>
                    <p>You may upload business permits, valid ID, proof of address, or shop-related documents.</p>
                </div>
            </div>

            <div class="info-step">
                <span>3</span>
                <div>
                    <strong>Admin review</strong>
                    <p>Your application will be checked before seller access is approved.</p>
                </div>
            </div>

            <div class="info-step">
                <span>4</span>
                <div>
                    <strong>Start managing products</strong>
                    <p>Once approved, you can add products, manage inventory, and monitor orders.</p>
                </div>
            </div>

            <div class="seller-note">
                Use accurate contact and business details so buyers and admins can verify your shop easily.
            </div>
        </div>

        <div class="seller-form-card">
            <h2>Application Form</h2>

            <form asp-controller="Shopper"
                  asp-action="ApplySeller"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-grid">
                    <div class="form-group">
                        <label asp-for="FullName">Full Name</label>
                        <input asp-for="FullName"
                               class="form-control"
                               placeholder="Enter your full name" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ShopName">Shop Name</label>
                        <input asp-for="ShopName"
                               class="form-control"
                               placeholder="Ex. Jieun Essentials" />
                        <span asp-validation-for="ShopName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PhoneNumber">Phone Number</label>
                        <input asp-for="PhoneNumber"
                               class="form-control"
                               placeholder="Ex. 09XXXXXXXXX" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Street / House No.</label>
                        <input type="text"
                               id="streetAddress"
                               class="form-control"
                               placeholder="Ex. Lot 576, Bago Village"
                               required />
                    </div>

                    <div class="form-group">
                        <label>Province</label>
                        <select id="provinceSelect" class="form-control" required>
                            <option value="">Select Province</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>City / Municipality</label>
                        <select id="citySelect" class="form-control" required disabled>
                            <option value="">Select City / Municipality</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Barangay</label>
                        <select id="barangaySelect" class="form-control" required disabled>
                            <option value="">Select Barangay</option>
                        </select>
                    </div>

                    <input asp-for="Address" type="hidden" id="finalAddress" />
                    <span asp-validation-for="Address" class="text-danger address-validation"></span>

                    <div class="form-group business-description-group">
                        <label asp-for="Documents">Upload Verification Documents</label>
                        <input asp-for="Documents"
                               type="file"
                               class="form-control"
                               multiple
                               accept=".pdf,.doc,.docx,.png,.jpg,.jpeg" />

                        <small class="text-muted">
                            Accepted files: PDF, DOC, DOCX, PNG, JPG, JPEG. You may upload multiple files.
                        </small>

                        <span asp-validation-for="Documents" class="text-danger"></span>
                    </div>

                    <div class="form-group business-description-group">
                        <label asp-for="BusinessDescription">Business Description</label>
                        <textarea asp-for="BusinessDescription"
                                  class="form-control business-description-textarea"
                                  rows="6"
                                  placeholder="Tell us what products you plan to sell and a short description of your shop."></textarea>
                        <span asp-validation-for="BusinessDescription" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="submit-application-btn">
                        Submit Application
                    </button>

                    <a asp-controller="Shopper"
                       asp-action="Index"
                       class="cancel-application-btn">
                        Cancel
                    </a>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const provinceSelect = document.getElementById("provinceSelect");
        const citySelect = document.getElementById("citySelect");
        const barangaySelect = document.getElementById("barangaySelect");
        const streetAddress = document.getElementById("streetAddress");
        const finalAddress = document.getElementById("finalAddress");

        function updateFinalAddress() {
            const street = streetAddress.value.trim();
            const barangay = barangaySelect.value;
            const city = citySelect.value;
            const province = provinceSelect.value;

            finalAddress.value = [street, barangay, city, province]
                .filter(x => x && x.trim() !== "")
                .join(", ");
        }

        async function loadProvinces() {
            try {
                const response = await fetch("https://psgc.gitlab.io/api/provinces/");
                const provinces = await response.json();

                provinces.sort((a, b) => a.name.localeCompare(b.name));

                provinces.forEach(province => {
                    const option = document.createElement("option");
                    option.value = province.name;
                    option.textContent = province.name;
                    option.dataset.code = province.code;
                    provinceSelect.appendChild(option);
                });
            } catch (error) {
                console.error("Failed to load provinces:", error);
            }
        }

        provinceSelect.addEventListener("change", async function () {
            citySelect.innerHTML = '<option value="">Select City / Municipality</option>';
            barangaySelect.innerHTML = '<option value="">Select Barangay</option>';

            citySelect.disabled = true;
            barangaySelect.disabled = true;
            updateFinalAddress();

            const selectedOption = provinceSelect.options[provinceSelect.selectedIndex];
            const provinceCode = selectedOption.dataset.code;

            if (!provinceCode) return;

            try {
                const response = await fetch(`https://psgc.gitlab.io/api/provinces/${provinceCode}/cities-municipalities/`);
                const cities = await response.json();

                cities.sort((a, b) => a.name.localeCompare(b.name));

                cities.forEach(city => {
                    const option = document.createElement("option");
                    option.value = city.name;
                    option.textContent = city.name;
                    option.dataset.code = city.code;
                    citySelect.appendChild(option);
                });

                citySelect.disabled = false;
            } catch (error) {
                console.error("Failed to load cities/municipalities:", error);
            }
        });

        citySelect.addEventListener("change", async function () {
            barangaySelect.innerHTML = '<option value="">Select Barangay</option>';
            barangaySelect.disabled = true;
            updateFinalAddress();

            const selectedOption = citySelect.options[citySelect.selectedIndex];
            const cityCode = selectedOption.dataset.code;

            if (!cityCode) return;

            try {
                const response = await fetch(`https://psgc.gitlab.io/api/cities-municipalities/${cityCode}/barangays/`);
                const barangays = await response.json();

                barangays.sort((a, b) => a.name.localeCompare(b.name));

                barangays.forEach(barangay => {
                    const option = document.createElement("option");
                    option.value = barangay.name;
                    option.textContent = barangay.name;
                    barangaySelect.appendChild(option);
                });

                barangaySelect.disabled = false;
            } catch (error) {
                console.error("Failed to load barangays:", error);
            }
        });

        streetAddress.addEventListener("input", updateFinalAddress);
        provinceSelect.addEventListener("change", updateFinalAddress);
        citySelect.addEventListener("change", updateFinalAddress);
        barangaySelect.addEventListener("change", updateFinalAddress);

        document.querySelector("form").addEventListener("submit", function () {
            updateFinalAddress();
        });

        loadProvinces();
    </script>
}