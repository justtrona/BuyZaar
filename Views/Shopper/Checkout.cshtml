@model BuyZaar.ViewModels.CheckoutViewModel

@{
    Layout = "_DashboardLayout";
    ViewBag.ActiveRole = "Shopper";
    ViewData["Title"] = "Checkout";
}

<link rel="stylesheet" href="~/css/checkout.css" asp-append-version="true" />

<div class="checkout-page">
    <div class="checkout-header">
        <h1>Checkout</h1>
        <p>Review your order and enter your receiver and delivery details.</p>
    </div>

    <form asp-controller="Shopper" asp-action="PlaceOrder" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="ProductName" />
        <input type="hidden" asp-for="ProductImage" />
        <input type="hidden" asp-for="Price" />
        <input type="hidden" asp-for="Quantity" />
        <input type="hidden" asp-for="Subtotal" />
        <input type="hidden" asp-for="SelectedVariant" />
        <input type="hidden" asp-for="SelectedSize" />
        <input type="hidden" asp-for="DeliveryAddress" />

        <div class="checkout-grid">
            <div class="checkout-card">
                <h2>Receiver Details</h2>

                <div class="address-grid">
                    <div>
                        <label asp-for="ReceiverName" class="section-label">Receiver Name</label>
                        <input asp-for="ReceiverName"
                               class="form-control"
                               placeholder="Full name of receiver"
                               required />
                    </div>

                    <div>
                        <label asp-for="ContactNumber" class="section-label">Contact Number</label>
                        <input asp-for="ContactNumber"
                               class="form-control"
                               placeholder="Ex. 09XXXXXXXXX"
                               required />
                    </div>
                </div>

                <h2 class="mt-4">Delivery Address</h2>

                <div class="address-grid">
                    <div>
                        <label asp-for="HouseNo" class="section-label">House No.</label>
                        <input asp-for="HouseNo" class="form-control" placeholder="Ex. 123" required />
                    </div>

                    <div>
                        <label asp-for="Street" class="section-label">Street</label>
                        <input asp-for="Street" class="form-control" placeholder="Ex. Mabini Street" required />
                    </div>

                    <div>
                        <label asp-for="Province" class="section-label">Province</label>
                        <select asp-for="Province" id="provinceSelect" class="form-control" required>
                            <option value="">Select Province</option>
                        </select>
                    </div>

                    <div>
                        <label asp-for="CityMunicipality" class="section-label">City / Municipality</label>
                        <select asp-for="CityMunicipality" id="citySelect" class="form-control" required disabled>
                            <option value="">Select City / Municipality</option>
                        </select>
                    </div>

                    <div>
                        <label asp-for="Barangay" class="section-label">Barangay</label>
                        <select asp-for="Barangay" id="barangaySelect" class="form-control" required disabled>
                            <option value="">Select Barangay</option>
                        </select>
                    </div>

                    <div>
                        <label asp-for="Landmark" class="section-label">Landmark</label>
                        <input asp-for="Landmark" class="form-control" placeholder="Ex. Near church" />
                    </div>
                </div>

                <div class="payment-options">
                    <div class="payment-option">
                        <input type="radio" checked disabled />
                        <div>
                            <strong>Cash on Delivery</strong>
                            <span>Pay when your order arrives.</span>
                        </div>
                    </div>

                    <div class="payment-option">
                        <input type="radio" disabled />
                        <div>
                            <strong>Online Payment</strong>
                            <span>Coming soon.</span>
                        </div>
                    </div>
                </div>

                <div class="secure-note">
                    Since this is Cash on Delivery, your order will go directly to To Ship.
                </div>
            </div>

            <div class="checkout-card">
                <h2>Order Summary</h2>

                <div class="order-item">
                    <img src="@Url.Content(Model.ProductImage)"
                         alt="@Model.ProductName"
                         class="product-thumb" />

                    <div class="order-info">
                        <h3>@Model.ProductName</h3>
                        <p>Variant: @(Model.SelectedVariant ?? "Default")</p>
                        <p>Size: @(Model.SelectedSize ?? "N/A")</p>
                        <p>Quantity: @Model.Quantity</p>
                    </div>
                </div>

                <div class="summary-row">
                    <span>Subtotal</span>
                    <strong>₱@Model.Subtotal.ToString("N2")</strong>
                </div>

                <div class="summary-row">
    <span>Shipping Fee</span>
    <strong>
        @(Model.ShippingFee == 0 ? "Free Shipping" : $"₱{Model.ShippingFee.ToString("N2")}")
    </strong>
</div>

<div class="summary-row total">
    <span>Total</span>
    <strong>₱@((Model.Subtotal + Model.ShippingFee).ToString("N2"))</strong>
</div>

                <div class="summary-row total">
                    <span>Total</span>
                    <strong>₱@Model.Subtotal.ToString("N2")</strong>
                </div>

                <div class="checkout-actions">
                    <button type="submit" class="btn-place-order">
                        Place Order
                    </button>

                    <a asp-controller="Shopper"
                       asp-action="ViewDetails"
                       asp-route-id="@Model.ProductId"
                       class="btn-cancel-order">
                        Cancel
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const provinceSelect = document.getElementById("provinceSelect");
        const citySelect = document.getElementById("citySelect");
        const barangaySelect = document.getElementById("barangaySelect");

        async function loadProvinces() {
            try {
                const response = await fetch("https://psgc.gitlab.io/api/provinces/");
                const provinces = await response.json();

                provinces.sort((a, b) => a.name.localeCompare(b.name));

                provinces.forEach(province => {
                    const option = document.createElement("option");
                    option.value = province.name;
                    option.textContent = province.name;
                    option.dataset.code = province.code;
                    provinceSelect.appendChild(option);
                });
            } catch (error) {
                console.error("Failed to load provinces:", error);
            }
        }

        provinceSelect.addEventListener("change", async function () {
            citySelect.innerHTML = '<option value="">Select City / Municipality</option>';
            barangaySelect.innerHTML = '<option value="">Select Barangay</option>';

            citySelect.disabled = true;
            barangaySelect.disabled = true;

            const selectedOption = provinceSelect.options[provinceSelect.selectedIndex];
            const provinceCode = selectedOption.dataset.code;

            if (!provinceCode) return;

            try {
                const response = await fetch(`https://psgc.gitlab.io/api/provinces/${provinceCode}/cities-municipalities/`);
                const cities = await response.json();

                cities.sort((a, b) => a.name.localeCompare(b.name));

                cities.forEach(city => {
                    const option = document.createElement("option");
                    option.value = city.name;
                    option.textContent = city.name;
                    option.dataset.code = city.code;
                    citySelect.appendChild(option);
                });

                citySelect.disabled = false;
            } catch (error) {
                console.error("Failed to load cities/municipalities:", error);
            }
        });

        citySelect.addEventListener("change", async function () {
            barangaySelect.innerHTML = '<option value="">Select Barangay</option>';
            barangaySelect.disabled = true;

            const selectedOption = citySelect.options[citySelect.selectedIndex];
            const cityCode = selectedOption.dataset.code;

            if (!cityCode) return;

            try {
                const response = await fetch(`https://psgc.gitlab.io/api/cities-municipalities/${cityCode}/barangays/`);
                const barangays = await response.json();

                barangays.sort((a, b) => a.name.localeCompare(b.name));

                barangays.forEach(barangay => {
                    const option = document.createElement("option");
                    option.value = barangay.name;
                    option.textContent = barangay.name;
                    barangaySelect.appendChild(option);
                });

                barangaySelect.disabled = false;
            } catch (error) {
                console.error("Failed to load barangays:", error);
            }
        });

        loadProvinces();
    </script>
}