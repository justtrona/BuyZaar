@model IEnumerable<BuyZaar.Models.Product>

@{
    Layout = "_DashboardLayout";
    ViewBag.ActiveRole = "Shopper";
    ViewData["Title"] = "Browse Products";

    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var selectedCategory = ViewBag.Category as string;
    var searchValue = ViewBag.Search as string;
    var selectedSort = ViewBag.Sort as string;
}

<link rel="stylesheet" href="~/css/product.css" asp-append-version="true" />

@section Styles {
    <style>
        .dashboard-topbar-actions {
            display: none !important;
        }

        .shopper-product-card {
            cursor: pointer;
        }
    </style>
}

@section TopbarContent {
    <div class="shoppee-mobile-topbar">

        <form asp-controller="Shopper"
              asp-action="BrowseProducts"
              method="get"
              class="shoppee-searchbar">

            <input type="text"
                   name="search"
                   value="@searchValue"
                   class="shoppee-search-input"
                   placeholder="Search products..." />

            <input type="hidden" name="category" value="@selectedCategory" />
            <input type="hidden" name="sort" value="@selectedSort" />

            <button type="submit" class="shoppee-search-btn">
                🔍
            </button>
        </form>

        <a asp-controller="Shopper"
           asp-action="MyCart"
           class="shoppee-icon-btn">
            🛒
            <span id="cartBadge" class="shoppee-badge">0</span>
        </a>

        <div class="dropdown">
            <button class="shoppee-icon-btn"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false">
                🔔
                <span class="shoppee-badge">3</span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end notification-dropdown">
                <li class="dropdown-header">Notifications</li>
                <li><a class="dropdown-item" href="#">Order is being prepared</a></li>
                <li><a class="dropdown-item" href="#">Cart item reminder</a></li>
                <li><a class="dropdown-item" href="#">Seller application update</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item text-center" href="#">View All</a></li>
            </ul>
        </div>

    </div>

    <form asp-controller="Shopper"
          asp-action="BrowseProducts"
          method="get"
          class="shoppee-filterbar">

        <input type="hidden" name="search" value="@searchValue" />

        <select name="category"
                class="form-control shoppee-select"
                onchange="this.form.submit()">
            <option value="">All Categories</option>

            @foreach (var category in categories)
            {
                <option value="@category" selected="@(selectedCategory == category)">
                    @category
                </option>
            }
        </select>

        <select name="sort"
                class="form-control shoppee-select"
                onchange="this.form.submit()">
            <option value="newest"
                    selected="@(selectedSort == "newest" || string.IsNullOrEmpty(selectedSort))">
                Newest
            </option>

            <option value="price_low" selected="@(selectedSort == "price_low")">
                Price: Low to High
            </option>

            <option value="price_high" selected="@(selectedSort == "price_high")">
                Price: High to Low
            </option>
        </select>

    </form>
}

<div class="products-page-shell">

    <p class="browse-subtitle">
        Search, filter, and discover products in the BuyZaar marketplace.
    </p>

    <div id="cartToast" class="cart-toast">
        Added to cart successfully.
    </div>

    @if (!Model.Any())
    {
        <div class="empty-products-state">
            <h3>No products found</h3>
            <p>Try changing your search or category filter.</p>
        </div>
    }
    else
    {
        <div class="browse-results-header">
            <p>Showing <strong>@Model.Count()</strong> product(s)</p>
        </div>

        <div class="shopper-products-grid">
            @foreach (var product in Model)
            {
                var firstImage = product.Images?.FirstOrDefault()?.ImagePath ?? "/images/no-image.png";
                var sellerName = product.Seller?.FullName ?? product.Seller?.UserName ?? "Unknown Seller";
                var hasColors = !string.IsNullOrWhiteSpace(product.AvailableVariants);
                var hasSizes = !string.IsNullOrWhiteSpace(product.AvailableSizes);
                var needsOptions = hasColors || hasSizes;
                var detailsUrl = Url.Action("ViewDetails", "Shopper", new { id = product.Id });

                <div class="shopper-product-card"
                     onclick="goToProductDetails('@detailsUrl')">

                    <div class="shopper-product-image-wrap">
                        <img src="@Url.Content(firstImage)"
                             class="shopper-product-img"
                             alt="@product.Name" />
                    </div>

                    <div class="shopper-product-body">
                        <span class="category-badge">
                            @product.Category
                        </span>

                        <h4>@product.Name</h4>

                        <small class="product-seller">
                            Store: @sellerName
                        </small>

                        <p class="shopper-product-desc">
                            @product.Description
                        </p>

                        <div class="product-card-options">
                            @if (hasColors)
                            {
                                <span>Colors available</span>
                            }

                            @if (hasSizes)
                            {
                                <span>Sizes available</span>
                            }
                        </div>

                        <div class="shopper-product-meta">
                            <strong>₱@product.Price.ToString("N2")</strong>
                            <span>@product.Stock in stock</span>
                        </div>

                        <div class="shopper-product-actions" onclick="event.stopPropagation();">
                            <a asp-controller="Shopper"
                               asp-action="ViewDetails"
                               asp-route-id="@product.Id"
                               class="btn btn-outline-primary btn-sm">
                                View Details
                            </a>

                            @if (needsOptions)
                            {
                                <a asp-controller="Shopper"
                                   asp-action="ViewDetails"
                                   asp-route-id="@product.Id"
                                   class="btn btn-primary btn-sm">
                                    Add to Cart
                                </a>
                            }
                            else
                            {
                                <form asp-controller="Shopper"
                                      asp-action="AddToCart"
                                      method="post"
                                      class="add-cart-form">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <input type="hidden" name="quantity" value="1" />

                                    <button type="submit" class="btn btn-primary btn-sm">
                                        Add to Cart
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        function goToProductDetails(url) {
            if (url) {
                window.location.href = url;
            }
        }

        document.querySelectorAll(".add-cart-form").forEach(form => {
            form.addEventListener("submit", function (e) {
                e.preventDefault();
                e.stopPropagation();

                const button = form.querySelector("button");
                const formData = new FormData(form);

                button.disabled = true;
                button.innerText = "Adding...";

                fetch(form.action, {
                    method: "POST",
                    body: formData
                })
                .then(response => {
                    if (response.ok) {
                        showCartToast();

                        const badge = document.getElementById("cartBadge");
                        if (badge) {
                            const current = parseInt(badge.innerText || "0");
                            badge.innerText = current + 1;
                        }

                        button.innerText = "Added";

                        setTimeout(() => {
                            button.disabled = false;
                            button.innerText = "Add to Cart";
                        }, 900);
                    } else {
                        alert("Unable to add product to cart.");
                        button.disabled = false;
                        button.innerText = "Add to Cart";
                    }
                })
                .catch(() => {
                    alert("Something went wrong.");
                    button.disabled = false;
                    button.innerText = "Add to Cart";
                });
            });
        });

        function showCartToast() {
            const toast = document.getElementById("cartToast");
            if (!toast) return;

            toast.classList.add("show");

            setTimeout(() => {
                toast.classList.remove("show");
            }, 1800);
        }
    </script>
}