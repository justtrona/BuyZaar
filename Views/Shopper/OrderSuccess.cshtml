@model BuyZaar.Models.Order

@{
    Layout = "_DashboardLayout";
    ViewBag.ActiveRole = "Shopper";
    ViewData["Title"] = "Order Success";
}

<link rel="stylesheet" href="~/css/ordersuccess.css" asp-append-version="true" />

<div class="order-success-page">

    <div class="success-hero">
        <div class="success-icon">✓</div>

        <div>
            <h1>Order Placed Successfully!</h1>
            <p>
                Thank you for your order. Your purchase is now being processed.
            </p>
        </div>
    </div>

    <div class="order-success-grid">

        <div class="success-main-card">

            <div class="section-header">
                <h2>Order Summary</h2>
                <span class="status-pill">@Model.Status</span>
            </div>

            <div class="order-info-box">
                <div>
                    <span>Order ID</span>
                    <strong>#@Model.Id</strong>
                </div>

                <div>
                    <span>Total Amount</span>
                    <strong>₱@Model.TotalAmount.ToString("N2")</strong>
                </div>

                <div>
                    <span>Date Ordered</span>
                    <strong>@Model.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</strong>
                </div>

                <div>
                    <span>Payment</span>
                    <strong>Cash on Delivery</strong>
                </div>
            </div>

            <div class="delivery-box">
                <h3>Delivery Details</h3>

                <div class="delivery-info">
                    <p><span>Receiver</span><strong>@Model.ReceiverName</strong></p>
                    <p><span>Contact</span><strong>@Model.ContactNumber</strong></p>
                    <p class="full"><span>Address</span><strong>@Model.DeliveryAddress</strong></p>
                </div>
            </div>

            <div class="items-box">
                <h3>Order Items</h3>

                @foreach (var item in Model.OrderItems)
                {
                    var product = item.Product;
                    var image = product?.Images?.FirstOrDefault()?.ImagePath ?? "/images/no-image.png";

                    <div class="order-item-success">
                        <div class="order-item-image-wrap">
                            <img src="@Url.Content(image)"
                                 alt="@(product?.Name ?? "Product")"
                                 class="order-item-img" />
                        </div>

                        <div class="order-item-info">
                            <strong>@(product?.Name ?? "Product")</strong>

                            <p>
                                Variant: @(item.SelectedVariant ?? "Default")
                            </p>

                            <p>
                                Size: @(item.SelectedSize ?? "N/A")
                            </p>

                            <p>
                                Qty: @item.Quantity
                            </p>
                        </div>

                        <strong class="item-price">
                            ₱@item.Subtotal.ToString("N2")
                        </strong>
                    </div>
                }
            </div>

        </div>

        <aside class="success-side-card">
            <h3>What happens next?</h3>

            <div class="timeline">
                <div class="timeline-item active">
                    <span></span>
                    <div>
                        <strong>Order Placed</strong>
                        <p>Your order was successfully submitted.</p>
                    </div>
                </div>

                <div class="timeline-item">
                    <span></span>
                    <div>
                        <strong>Seller Processing</strong>
                        <p>The seller will prepare your item.</p>
                    </div>
                </div>

                <div class="timeline-item">
                    <span></span>
                    <div>
                        <strong>Out for Delivery</strong>
                        <p>Your rider will deliver the order.</p>
                    </div>
                </div>

                <div class="timeline-item">
                    <span></span>
                    <div>
                        <strong>Completed</strong>
                        <p>Receive your order and enjoy shopping.</p>
                    </div>
                </div>
            </div>

            <div class="success-actions">
                <a asp-controller="Shopper"
                   asp-action="BrowseProducts"
                   class="btn-continue">
                    Continue Shopping
                </a>

                <a asp-controller="Shopper"
                   asp-action="MyOrders"
                   class="btn-secondary-action">
                    View My Orders
                </a>
            </div>
        </aside>

    </div>
</div>