@model BuyZaar.Models.ApplicationUser

@{
    Layout = "_DashboardLayout";
    ViewBag.ActiveRole = "Shopper";
    ViewData["Title"] = "Shopper Profile";

    var sellerStatus = ViewBag.SellerApplicationStatus as string ?? "Not Applied";
    var latestApplication = ViewBag.LatestSellerApplication as BuyZaar.Models.SellerApplication;

    var totalOrders = ViewBag.TotalOrders ?? 0;
    var cartItems = ViewBag.CartItems ?? 0;
    var pendingDeliveries = ViewBag.PendingDeliveries ?? 0;
    var recentOrders = ViewBag.RecentOrders as List<BuyZaar.Models.Order> ?? new();
}

<link rel="stylesheet" href="~/css/shopperprofile.css" asp-append-version="true" />

<div class="shopper-profile-page">

    <div class="profile-hero">
        <div class="profile-user">
            <div class="profile-avatar">
                @((User.Identity?.Name ?? "U").Substring(0, 1).ToUpper())
            </div>

            <div>
                <span class="role-badge">Shopper</span>
                <h1>Hello, @User.Identity?.Name!</h1>
                <p>Manage your orders, cart, deliveries, and seller application.</p>
            </div>
        </div>

        <a asp-controller="Shopper"
           asp-action="BrowseProducts"
           class="btn-main">
            Browse Products
        </a>
    </div>

    @if (TempData["ApplicationMessage"] != null)
    {
        <div class="profile-alert">
            @TempData["ApplicationMessage"]
        </div>
    }

    <div class="profile-stats">
        <a asp-controller="Shopper" asp-action="MyOrders" class="stat-card">
            <span>My Orders</span>
            <strong>@totalOrders</strong>
            <p>Total orders placed</p>
        </a>

        <a asp-controller="Shopper" asp-action="MyCart" class="stat-card">
            <span>Cart Items</span>
            <strong>@cartItems</strong>
            <p>Items waiting in cart</p>
        </a>

        <a asp-controller="Shopper" asp-action="MyOrders" asp-route-status="To Receive" class="stat-card">
            <span>Pending Deliveries</span>
            <strong>@pendingDeliveries</strong>
            <p>Orders to receive</p>
        </a>

        @if (latestApplication != null)
        {
            <button type="button"
                    class="stat-card stat-card-button"
                    data-bs-toggle="modal"
                    data-bs-target="#sellerApplicationModal">
                <span>Seller Status</span>
                <strong class="status-text">@sellerStatus</strong>
                <p>Click to view application</p>
            </button>
        }
        else
        {
            <a asp-controller="Shopper"
               asp-action="ApplySeller"
               class="stat-card">
                <span>Seller Status</span>
                <strong class="status-text">@sellerStatus</strong>
                <p>Apply as seller</p>
            </a>
        }
    </div>

    <div class="profile-grid">

        <div class="profile-card">
            <div class="profile-card-header">
                <h2>Profile Information</h2>
                <button type="button" class="edit-profile-btn" onclick="toggleEditProfile()">
                    Edit
                </button>
            </div>

            @if (TempData["ProfileMessage"] != null)
            {
                <div class="profile-alert small-alert">
                    @TempData["ProfileMessage"]
                </div>
            }

            <div id="profileView" class="info-list">
                <div>
                    <span>Username</span>
                    <strong>@User.Identity?.Name</strong>
                </div>

                <div>
                    <span>Full Name</span>
                    <strong>@(Model.FullName ?? "Not set")</strong>
                </div>

                <div>
                    <span>Email</span>
                    <strong>@(Model.Email ?? "Not set")</strong>
                </div>

                <div>
                    <span>Phone Number</span>
                    <strong>@(Model.PhoneNumber ?? "Not set")</strong>
                </div>
            </div>

            <form id="profileEditForm"
                  asp-controller="Shopper"
                  asp-action="UpdateProfile"
                  method="post"
                  class="profile-edit-form"
                  style="display:none;">
                @Html.AntiForgeryToken()

                <div>
                    <label>Username</label>
                    <input value="@User.Identity?.Name" class="form-control" disabled />
                </div>

                <div>
                    <label>Email</label>
                    <input value="@Model.Email" class="form-control" disabled />
                </div>

                <div>
                    <label>Full Name</label>
                    <input name="fullName"
                           value="@Model.FullName"
                           class="form-control"
                           placeholder="Enter your full name"
                           required />
                </div>

                <div>
                    <label>Phone Number</label>
                    <input name="phoneNumber"
                           value="@Model.PhoneNumber"
                           class="form-control"
                           placeholder="Ex. 09XXXXXXXXX" />
                </div>

                <div class="profile-edit-actions">
                    <button type="submit" class="save-profile-btn">
                        Save Changes
                    </button>

                    <button type="button" class="cancel-profile-btn" onclick="toggleEditProfile()">
                        Cancel
                    </button>
                </div>
            </form>
        </div>

        <div class="profile-card">
            <h2>Quick Actions</h2>

            <div class="quick-actions">
                <a asp-controller="Shopper" asp-action="BrowseProducts">Browse Products</a>
                <a asp-controller="Shopper" asp-action="MyCart">View Cart</a>
                <a asp-controller="Shopper" asp-action="MyOrders">My Orders</a>

                @if (sellerStatus == "Not Applied")
                {
                    <a asp-controller="Shopper" asp-action="ApplySeller">
                        Apply as Seller
                    </a>
                }
                else if (sellerStatus == "Approved")
                {
                    <a asp-controller="Seller" asp-action="Index">
                        Switch to Seller
                    </a>
                }
                else if (latestApplication != null)
                {
                    <button type="button"
                            class="quick-action-button"
                            data-bs-toggle="modal"
                            data-bs-target="#sellerApplicationModal">
                        View Seller Application
                    </button>
                }
                else
                {
                    <span class="disabled-action">
                        Seller Application: @sellerStatus
                    </span>
                }
            </div>
        </div>
    </div>

    <div class="profile-card recent-orders-card">
        <div class="section-title">
            <div>
                <h2>Recent Orders</h2>
                <p>Your latest shopping activity.</p>
            </div>

            <a asp-controller="Shopper" asp-action="MyOrders">
                View All
            </a>
        </div>

        @if (!recentOrders.Any())
        {
            <div class="empty-recent">
                <h3>No recent orders</h3>
                <p>Start shopping to see your orders here.</p>
            </div>
        }
        else
        {
            <div class="recent-orders-list">
                @foreach (var order in recentOrders)
                {
                    var firstItem = order.OrderItems.FirstOrDefault();
                    var productName = firstItem?.Product?.Name ?? "Product";

                    <a asp-controller="Shopper"
                       asp-action="OrderDetails"
                       asp-route-id="@order.Id"
                       class="recent-order-item">

                        <div>
                            <strong>Order #@order.Id</strong>
                            <p>@productName</p>
                        </div>

                        <div>
                            <span class="order-status">@order.Status</span>
                            <strong>₱@order.TotalAmount.ToString("N2")</strong>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>

@if (latestApplication != null)
{
    <div class="modal fade" id="sellerApplicationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content seller-modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title">Seller Application Details</h5>
                        <small>Submitted on @latestApplication.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</small>
                    </div>

                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <div class="seller-status-pill">
                        Status: <strong>@latestApplication.Status</strong>
                    </div>

                    <div class="seller-modal-grid">
                        <div>
                            <span>Full Name</span>
                            <strong>@latestApplication.FullName</strong>
                        </div>

                        <div>
                            <span>Shop Name</span>
                            <strong>@latestApplication.ShopName</strong>
                        </div>

                        <div>
                            <span>Phone Number</span>
                            <strong>@latestApplication.PhoneNumber</strong>
                        </div>

                        <div>
                            <span>Business Address</span>
                            <strong>@latestApplication.Address</strong>
                        </div>

                        <div class="seller-modal-full">
                            <span>Business Description</span>
                            <strong>@latestApplication.BusinessDescription</strong>
                        </div>
                    </div>

                    <div class="seller-documents-modal">
                        <h6>Uploaded Documents</h6>

                        @if (latestApplication.Documents != null && latestApplication.Documents.Any())
                        {
                            foreach (var document in latestApplication.Documents)
                            {
                                <div class="seller-document-row">
                                    <div>
                                        <strong>@document.FileName</strong>
                                        <p>@document.ContentType · @(document.FileSize / 1024) KB</p>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted mb-0">No documents uploaded.</p>
                        }
                    </div>
                </div>

                <div class="modal-footer">
                    @if (latestApplication.Status == "Pending")
                    {
                        <form asp-controller="Shopper"
                              asp-action="CancelSellerApplication"
                              method="post"
                              onsubmit="return confirm('Are you sure you want to cancel your seller application?');">
                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   name="applicationId"
                                   value="@latestApplication.Id" />

                            <button type="submit" class="btn btn-danger">
                                Cancel Application
                            </button>
                        </form>
                    }

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Close
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        function toggleEditProfile() {
            const view = document.getElementById("profileView");
            const form = document.getElementById("profileEditForm");

            if (form.style.display === "none") {
                form.style.display = "grid";
                view.style.display = "none";
            } else {
                form.style.display = "none";
                view.style.display = "grid";
            }
        }
    </script>
}