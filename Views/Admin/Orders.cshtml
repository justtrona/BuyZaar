@model IEnumerable<BuyZaar.Models.Order>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Orders";

    var recommendedRiders =
        ViewBag.RecommendedRiders as Dictionary<int, List<BuyZaar.Models.RiderProfile>>
        ?? new Dictionary<int, List<BuyZaar.Models.RiderProfile>>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-orders.css" asp-append-version="true" />
}

<div class="admin-orders-page">

    @* <div class="admin-orders-header">
        <div>
            <h2>Manage Orders</h2>
            <p>Manage BuyZaar system operations</p>
        </div>
    </div> *@

    <div class="orders-page-hero">
        <div>
            <h1>Manage Orders</h1>
            <p>Assign riders, monitor delivery, and complete return-to-seller orders.</p>
        </div>

        <span class="orders-page-count">
            @Model.Count() Order(s)
        </span>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info admin-orders-alert">
            @TempData["Message"]
        </div>
    }

    <div class="orders-table-card">

        <div class="orders-card-header">
            <h3>Order Records</h3>
            <p>Track orders, riders, delivery statuses, and return processing.</p>
        </div>

        <div class="orders-filter-card">
            <div class="orders-filter-group orders-filter-search">
                <input type="text"
                       id="orderSearchInput"
                       placeholder="Search order ID, receiver, contact, or address..." />
            </div>

            <div class="orders-filter-group">
                <select id="orderStatusFilter">
                    <option value="">All Order Status</option>
                    <option value="Pending">Pending</option>
                    <option value="Processing">Processing</option>
                    <option value="Ready for Pickup">Ready for Pickup</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>

            <div class="orders-filter-group">
                <select id="deliveryStatusFilter">
                    <option value="">All Delivery Status</option>
                    <option value="Pending Assignment">Pending Assignment</option>
                    <option value="Assigned">Assigned</option>
                    <option value="Picked Up">Picked Up</option>
                    <option value="Out for Delivery">Out for Delivery</option>
                    <option value="Delivered">Delivered</option>
                    <option value="Return Pending">Return Pending</option>
                    <option value="Returned to Seller">Returned to Seller</option>
                </select>
            </div>

            <div class="orders-filter-group">
                <select id="riderFilter">
                    <option value="">All Riders</option>
                    <option value="assigned">Assigned</option>
                    <option value="not-assigned">Not Assigned</option>
                </select>
            </div>

            <button type="button" id="orderFilterBtn" class="orders-filter-btn">
                Filter
            </button>

            <button type="button" id="orderResetBtn" class="orders-reset-btn">
                Reset
            </button>
        </div>

        @if (!Model.Any())
        {
            <div class="orders-empty-state">
                <h5>No orders found</h5>
                <p>Orders will appear here once shoppers place orders.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table orders-table align-middle">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Receiver</th>
                            <th>Contact</th>
                            <th>Address</th>
                            <th>Total</th>
                            <th>Order Status</th>
                            <th>Delivery Status</th>
                            <th>Assigned Rider</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var order in Model)
                        {
                            var recommendedForOrder =
                                recommendedRiders.ContainsKey(order.Id)
                                    ? recommendedRiders[order.Id]
                                    : new List<BuyZaar.Models.RiderProfile>();

                            var deliveryStatus = string.IsNullOrWhiteSpace(order.DeliveryStatus)
                                ? "Pending Assignment"
                                : order.DeliveryStatus;

                            var riderState = order.Rider != null ? "assigned" : "not-assigned";

                            <tr class="order-row"
                                data-search="@($"#{order.Id} {order.Id} {order.ReceiverName} {order.ContactNumber} {order.DeliveryAddress} {order.Rider?.FullName} {order.Rider?.Email}".ToLower())"
                                data-order-status="@order.Status"
                                data-delivery-status="@deliveryStatus"
                                data-rider="@riderState">

                                <td class="fw-bold">#@order.Id</td>

                                <td>@order.ReceiverName</td>

                                <td>@order.ContactNumber</td>

                                <td class="order-address">
                                    @order.DeliveryAddress
                                </td>

                                <td>
                                    ₱@order.TotalAmount.ToString("N2")
                                </td>

                                <td>
                                    <span class="order-status-badge">
                                        @order.Status
                                    </span>
                                </td>

                                <td>
                                    <span class="delivery-status-badge">
                                        @deliveryStatus
                                    </span>
                                </td>

                                <td>
                                    @if (order.Rider != null)
                                    {
                                        <div class="assigned-rider-box">
                                            <strong>@order.Rider.FullName</strong>
                                            <small>@order.Rider.Email</small>

                                            <form asp-controller="Admin"
                                                  asp-action="UnassignRider"
                                                  method="post"
                                                  class="mt-2"
                                                  onsubmit="return confirm('Remove this rider from Order #@order.Id?');">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="orderId"
                                                       value="@order.Id" />

                                                <button type="submit"
                                                        class="btn btn-sm btn-danger unassign-btn">
                                                    Remove Rider
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="not-assigned-text">
                                            Not assigned
                                        </span>
                                    }
                                </td>

                                <td>
                                    @order.CreatedAt.ToString("yyyy-MM-dd")
                                </td>

                                <td>
                                    @if (deliveryStatus == "Return Pending")
                                    {
                                        <form asp-controller="Admin"
                                              asp-action="MarkReturnedToSeller"
                                              method="post"
                                              onsubmit="return confirm('Mark Order #@order.Id as returned to seller?');">

                                            @Html.AntiForgeryToken()

                                            <input type="hidden"
                                                   name="orderId"
                                                   value="@order.Id" />

                                            <button type="submit"
                                                    class="btn btn-success btn-sm">
                                                Mark Returned
                                            </button>
                                        </form>
                                    }
                                    else if (deliveryStatus == "Returned to Seller")
                                    {
                                        <span class="already-assigned-note">
                                            Returned to seller.
                                        </span>
                                    }
                                    else if (order.Rider != null)
                                    {
                                        <span class="already-assigned-note">
                                            Rider already assigned.
                                        </span>
                                    }
                                    else if (order.Status != "Ready for Pickup")
                                    {
                                        <div class="waiting-pickup-box">
                                            <strong>Waiting for Seller</strong>
                                            <small>
                                                Assignment opens when order is <b>Ready for Pickup</b>.
                                            </small>
                                        </div>
                                    }
                                    else
                                    {
                                        if (recommendedForOrder.Any())
                                        {
                                            <form asp-controller="Admin"
                                                  asp-action="AssignRider"
                                                  method="post"
                                                  class="assign-rider-form">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="orderId"
                                                       value="@order.Id" />

                                                <select name="riderId"
                                                        class="form-select form-select-sm"
                                                        required>
                                                    <option value="">Select nearby rider</option>

                                                    @foreach (var rider in recommendedForOrder)
                                                    {
                                                        <option value="@rider.UserId">
                                                            @rider.FullName - @rider.AssignedLocation
                                                        </option>
                                                    }
                                                </select>

                                                <small class="recommended-note">
                                                    Only nearby riders can be assigned.
                                                </small>

                                                <button type="submit"
                                                        class="btn btn-primary btn-sm mt-2">
                                                    Assign Rider
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <div class="no-rider-box">
                                                <strong>No nearby rider available</strong>
                                                <small>
                                                    Create or activate a rider assigned near this buyer address.
                                                </small>
                                            </div>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div id="ordersNoResults" class="orders-no-results d-none">
                <h5>No matching orders found</h5>
                <p>Try changing your search or filter options.</p>
            </div>
        }

    </div>
</div>

@section Scripts {
    <script>
        const orderSearchInput = document.getElementById("orderSearchInput");
        const orderStatusFilter = document.getElementById("orderStatusFilter");
        const deliveryStatusFilter = document.getElementById("deliveryStatusFilter");
        const riderFilter = document.getElementById("riderFilter");
        const orderFilterBtn = document.getElementById("orderFilterBtn");
        const orderResetBtn = document.getElementById("orderResetBtn");
        const ordersNoResults = document.getElementById("ordersNoResults");

        function filterOrders() {
            const searchValue = orderSearchInput.value.toLowerCase().trim();
            const orderStatusValue = orderStatusFilter.value;
            const deliveryStatusValue = deliveryStatusFilter.value;
            const riderValue = riderFilter.value;

            let visibleCount = 0;

            document.querySelectorAll(".order-row").forEach(row => {
                const rowSearch = row.dataset.search || "";
                const rowOrderStatus = row.dataset.orderStatus || "";
                const rowDeliveryStatus = row.dataset.deliveryStatus || "";
                const rowRider = row.dataset.rider || "";

                const matchesSearch = !searchValue || rowSearch.includes(searchValue);
                const matchesOrderStatus = !orderStatusValue || rowOrderStatus === orderStatusValue;
                const matchesDeliveryStatus = !deliveryStatusValue || rowDeliveryStatus === deliveryStatusValue;
                const matchesRider = !riderValue || rowRider === riderValue;

                const isVisible =
                    matchesSearch &&
                    matchesOrderStatus &&
                    matchesDeliveryStatus &&
                    matchesRider;

                row.style.display = isVisible ? "" : "none";

                if (isVisible) {
                    visibleCount++;
                }
            });

            if (ordersNoResults) {
                ordersNoResults.classList.toggle("d-none", visibleCount > 0);
            }
        }

        orderFilterBtn.addEventListener("click", filterOrders);

        orderResetBtn.addEventListener("click", function () {
            orderSearchInput.value = "";
            orderStatusFilter.value = "";
            deliveryStatusFilter.value = "";
            riderFilter.value = "";
            filterOrders();
        });

        orderSearchInput.addEventListener("keyup", filterOrders);
        orderStatusFilter.addEventListener("change", filterOrders);
        deliveryStatusFilter.addEventListener("change", filterOrders);
        riderFilter.addEventListener("change", filterOrders);
    </script>
}