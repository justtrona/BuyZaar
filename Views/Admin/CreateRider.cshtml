@model BuyZaar.ViewModels.CreateRiderViewModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Create Rider";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-riders.css" asp-append-version="true" />
}

<div class="rider-page">

    <div class="rider-header">
        <div>
            <h2>Create Rider Account</h2>
            <p>Create a rider account for newly hired delivery personnel.</p>
        </div>

        <a asp-controller="Admin" asp-action="Riders" class="btn btn-outline-secondary">
            Back to Riders
        </a>
    </div>

    <div class="rider-form-card">
        <form asp-action="CreateRider" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="rider-form-grid">

                <div class="form-group">
                    <label asp-for="FullName"></label>
                    <input asp-for="FullName" class="form-control" placeholder="Enter rider full name" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" placeholder="Enter rider email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PhoneNumber"></label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="09XXXXXXXXX" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>Street / House No.</label>
                    <input type="text" id="streetAddress" class="form-control" placeholder="Ex. Lot 576, Main Street" required />
                </div>

                <div class="form-group">
                    <label>Province</label>
                    <select id="provinceSelect" class="form-control" required>
                        <option value="">Select Province</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>City / Municipality</label>
                    <select id="citySelect" class="form-control" required disabled>
                        <option value="">Select City / Municipality</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Barangay</label>
                    <select id="barangaySelect" class="form-control" required disabled>
                        <option value="">Select Barangay</option>
                    </select>
                </div>

                <input asp-for="AssignedLocation" type="hidden" id="finalAddress" />
                <span asp-validation-for="AssignedLocation" class="text-danger full-width"></span>

                <div class="form-group full-width">
                    <label asp-for="VehicleType"></label>
                    <input asp-for="VehicleType" class="form-control" placeholder="Ex. Motorcycle" />
                    <span asp-validation-for="VehicleType" class="text-danger"></span>
                </div>

            </div>

            <div class="rider-actions">
                <button type="submit" class="btn btn-primary create-rider-btn">
                    Create Rider Account
                </button>

                <a asp-controller="Admin" asp-action="Riders" class="btn btn-light cancel-btn">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const provinceSelect = document.getElementById("provinceSelect");
        const citySelect = document.getElementById("citySelect");
        const barangaySelect = document.getElementById("barangaySelect");
        const streetAddress = document.getElementById("streetAddress");
        const finalAddress = document.getElementById("finalAddress");

        function updateFinalAddress() {
            const street = streetAddress.value.trim();
            const barangay = barangaySelect.value;
            const city = citySelect.value;
            const province = provinceSelect.value;

            finalAddress.value = [street, barangay, city, province]
                .filter(x => x && x.trim() !== "")
                .join(", ");
        }

        async function loadProvinces() {
            const response = await fetch("https://psgc.gitlab.io/api/provinces/");
            const provinces = await response.json();

            provinces.sort((a, b) => a.name.localeCompare(b.name));

            provinces.forEach(province => {
                const option = document.createElement("option");
                option.value = province.name;
                option.textContent = province.name;
                option.dataset.code = province.code;
                provinceSelect.appendChild(option);
            });
        }

        provinceSelect.addEventListener("change", async function () {
            citySelect.innerHTML = '<option value="">Select City / Municipality</option>';
            barangaySelect.innerHTML = '<option value="">Select Barangay</option>';
            citySelect.disabled = true;
            barangaySelect.disabled = true;

            updateFinalAddress();

            const provinceCode = provinceSelect.options[provinceSelect.selectedIndex].dataset.code;
            if (!provinceCode) return;

            const response = await fetch(`https://psgc.gitlab.io/api/provinces/${provinceCode}/cities-municipalities/`);
            const cities = await response.json();

            cities.sort((a, b) => a.name.localeCompare(b.name));

            cities.forEach(city => {
                const option = document.createElement("option");
                option.value = city.name;
                option.textContent = city.name;
                option.dataset.code = city.code;
                citySelect.appendChild(option);
            });

            citySelect.disabled = false;
        });

        citySelect.addEventListener("change", async function () {
            barangaySelect.innerHTML = '<option value="">Select Barangay</option>';
            barangaySelect.disabled = true;

            updateFinalAddress();

            const cityCode = citySelect.options[citySelect.selectedIndex].dataset.code;
            if (!cityCode) return;

            const response = await fetch(`https://psgc.gitlab.io/api/cities-municipalities/${cityCode}/barangays/`);
            const barangays = await response.json();

            barangays.sort((a, b) => a.name.localeCompare(b.name));

            barangays.forEach(barangay => {
                const option = document.createElement("option");
                option.value = barangay.name;
                option.textContent = barangay.name;
                barangaySelect.appendChild(option);
            });

            barangaySelect.disabled = false;
        });

        streetAddress.addEventListener("input", updateFinalAddress);
        provinceSelect.addEventListener("change", updateFinalAddress);
        citySelect.addEventListener("change", updateFinalAddress);
        barangaySelect.addEventListener("change", updateFinalAddress);

        document.querySelector("form").addEventListener("submit", function () {
            updateFinalAddress();
        });

        loadProvinces();
    </script>
}