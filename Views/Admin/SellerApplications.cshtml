@model IEnumerable<BuyZaar.Models.SellerApplication>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Seller Applications";
}

@section Styles {
    <link rel="stylesheet"
          href="~/css/admin-sellerapplication.css"
          asp-append-version="true" />
}

<div class="seller-app-page">

    <div class="seller-app-hero">
        <div>
            <h1>Seller Applications</h1>
            <p>Review seller account requests, verify submitted details, and manage approvals.</p>
        </div>

        <span class="seller-app-count">
            @Model.Count() Application(s)
        </span>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert seller-app-alert">
            @TempData["Message"]
        </div>
    }

    <div class="seller-app-card">

        <div class="seller-app-card-header">
            <div>
                <h3>Application Records</h3>
                <p>Seller applications submitted by users.</p>
            </div>

            <a asp-controller="Admin"
               asp-action="Index"
               class="seller-back-btn">
                Back to Dashboard
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="seller-empty-state">
                <h5>No seller applications found</h5>
                <p>There are currently no seller applications to review.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table seller-app-table align-middle">
                    <thead>
                        <tr>
                            <th>Applicant</th>
                            <th>Shop</th>
                            <th>Contact</th>
                            <th>Address</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Date Applied</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var app in Model)
                        {
                            var statusClass = app.Status switch
                            {
                                "Pending" => "pending",
                                "Approved" => "approved",
                                "Rejected" => "rejected",
                                "Cancelled" => "cancelled",
                                _ => "default"
                            };

                            var modalId = $"sellerApplicationModal_{app.Id}";
                            var applicantInitial = (app.FullName ?? "S").Substring(0, 1).ToUpper();

                            <tr>
                                <td>
                                    <div class="seller-applicant-cell">
                                        <div class="seller-app-avatar">
                                            @applicantInitial
                                        </div>

                                        <div>
                                            <strong>@app.FullName</strong>
                                            <span>@(app.User?.Email ?? "No email")</span>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <div class="seller-shop-cell">
                                        <strong>@app.ShopName</strong>
                                        <span>Seller request</span>
                                    </div>
                                </td>

                                <td>
                                    <div class="seller-contact-cell">
                                        <strong>@app.PhoneNumber</strong>
                                        <span>@(app.User?.Email ?? "No email")</span>
                                    </div>
                                </td>

                                <td>
                                    <span class="seller-address-text">
                                        @app.Address
                                    </span>
                                </td>

                                <td>
                                    <span class="seller-description-text">
                                        @if (!string.IsNullOrWhiteSpace(app.BusinessDescription))
                                        {
                                            @(app.BusinessDescription.Length > 45
                                                ? app.BusinessDescription.Substring(0, 45) + "..."
                                                : app.BusinessDescription)
                                        }
                                        else
                                        {
                                            <span class="text-muted">No description</span>
                                        }
                                    </span>
                                </td>

                                <td>
                                    <span class="seller-status-badge @statusClass">
                                        @app.Status
                                    </span>
                                </td>

                                <td>
                                    <span class="seller-date-text">
                                        @app.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                                    </span>
                                </td>

                                <td class="text-end">
                                    <div class="seller-action-group">
                                        <button type="button"
                                                class="seller-view-btn"
                                                data-bs-toggle="modal"
                                                data-bs-target="#@modalId">
                                            View
                                        </button>

                                        @if (app.Status == "Pending")
                                        {
                                            <form asp-action="ApproveSeller"
                                                  method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@app.Id" />

                                                <button type="submit" class="seller-approve-btn">
                                                    Approve
                                                </button>
                                            </form>

                                            <form asp-action="RejectSeller"
                                                  method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@app.Id" />

                                                <button type="submit" class="seller-reject-btn">
                                                    Reject
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>

                            <div class="modal fade"
                                 id="@modalId"
                                 tabindex="-1"
                                 aria-labelledby="@($"{modalId}_Label")"
                                 aria-hidden="true">

                                <div class="modal-dialog modal-dialog-centered modal-lg">
                                    <div class="modal-content seller-modal-content">

                                        <div class="modal-header seller-modal-header">
                                            <div>
                                                <h5 class="modal-title" id="@($"{modalId}_Label")">
                                                    Seller Application Details
                                                </h5>
                                                <p>Submitted by @app.FullName</p>
                                            </div>

                                            <button type="button"
                                                    class="btn-close btn-close-white"
                                                    data-bs-dismiss="modal"
                                                    aria-label="Close">
                                            </button>
                                        </div>

                                        <div class="modal-body seller-modal-body">

                                            <div class="seller-detail-grid">

                                                <div class="seller-detail-item">
                                                    <span>Full Name</span>
                                                    <strong>@app.FullName</strong>
                                                </div>

                                                <div class="seller-detail-item">
                                                    <span>Shop Name</span>
                                                    <strong>@app.ShopName</strong>
                                                </div>

                                                <div class="seller-detail-item">
                                                    <span>Email</span>
                                                    <strong>@(app.User?.Email ?? "No email")</strong>
                                                </div>

                                                <div class="seller-detail-item">
                                                    <span>Phone Number</span>
                                                    <strong>@app.PhoneNumber</strong>
                                                </div>

                                                <div class="seller-detail-item full-width">
                                                    <span>Address</span>
                                                    <strong>@app.Address</strong>
                                                </div>

                                                <div class="seller-detail-item full-width">
                                                    <span>Business Description</span>
                                                    <strong>
                                                        @(string.IsNullOrWhiteSpace(app.BusinessDescription)
                                                            ? "No business description provided."
                                                            : app.BusinessDescription)
                                                    </strong>
                                                </div>

                                                <div class="seller-detail-item">
                                                    <span>Status</span>
                                                    <strong>
                                                        <span class="seller-status-badge @statusClass">
                                                            @app.Status
                                                        </span>
                                                    </strong>
                                                </div>

                                                <div class="seller-detail-item">
                                                    <span>Date Applied</span>
                                                    <strong>@app.CreatedAt.ToString("yyyy-MM-dd HH:mm")</strong>
                                                </div>

                                            </div>

                                            <div class="admin-uploaded-documents">
                                                <h6>Uploaded Documents</h6>

                                                @if (app.Documents != null && app.Documents.Any())
                                                {
                                                    <div class="admin-document-list">
                                                        @foreach (var doc in app.Documents)
                                                        {
                                                            <a href="@doc.FilePath"
                                                               target="_blank"
                                                               class="admin-document-item">

                                                                <div>
                                                                    <strong>@doc.FileName</strong>
                                                                    <span>
                                                                        @doc.ContentType · @(Math.Round((double)doc.FileSize / 1024, 0)) KB
                                                                    </span>
                                                                </div>

                                                                <span class="admin-document-view">
                                                                    View
                                                                </span>
                                                            </a>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="admin-no-documents">
                                                        No uploaded documents found.
                                                    </div>
                                                }
                                            </div>

                                        </div>

                                        <div class="modal-footer seller-modal-footer">
                                            <button type="button"
                                                    class="seller-modal-close"
                                                    data-bs-dismiss="modal">
                                                Close
                                            </button>

                                            @if (app.Status == "Pending")
                                            {
                                                <form asp-action="ApproveSeller" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@app.Id" />

                                                    <button type="submit" class="seller-approve-btn">
                                                        Approve Application
                                                    </button>
                                                </form>

                                                <form asp-action="RejectSeller" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@app.Id" />

                                                    <button type="submit" class="seller-reject-btn">
                                                        Reject Application
                                                    </button>
                                                </form>
                                            }
                                        </div>

                                    </div>
                                </div>
                            </div>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>