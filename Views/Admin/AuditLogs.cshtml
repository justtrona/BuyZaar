@model List<BuyZaar.Models.AuditLog>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Audit Logs";

    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var totalLogs = ViewBag.TotalLogs as int? ?? Model.Count;
}

@section Styles {
    <link rel="stylesheet"
          href="~/css/admin-auditlogs.css"
          asp-append-version="true" />
}

<div class="audit-header">
    <div>
        <h1>Audit Logs</h1>
        <p>Track important admin actions, moderation activity, and account changes.</p>
    </div>
</div>

<div class="audit-card">

    <div class="audit-summary">
        <div>
            <h3>Recent Admin Activities</h3>
            <p>@totalLogs log(s) found · Page @currentPage of @(totalPages == 0 ? 1 : totalPages)</p>
        </div>
    </div>

    <form asp-controller="Admin"
          asp-action="AuditLogs"
          method="get"
          class="audit-filter-form">

        <input type="text"
               name="search"
               value="@ViewBag.Search"
               class="form-control"
               placeholder="Search admin, action, entity, description..." />

        <select name="actionFilter" class="form-select">
            <option value="">All Actions</option>
            @foreach (var action in ViewBag.ActionOptions)
            {
                <option value="@action" selected="@(ViewBag.ActionFilter == action)">
                    @action
                </option>
            }
        </select>

        <select name="entityFilter" class="form-select">
            <option value="">All Entities</option>
            @foreach (var entity in ViewBag.EntityOptions)
            {
                <option value="@entity" selected="@(ViewBag.EntityFilter == entity)">
                    @entity
                </option>
            }
        </select>

        <input type="date"
               name="fromDate"
               value="@ViewBag.FromDate"
               class="form-control" />

        <input type="date"
               name="toDate"
               value="@ViewBag.ToDate"
               class="form-control" />

        <button type="submit" class="audit-filter-btn">
            Filter
        </button>

        <a asp-controller="Admin"
           asp-action="AuditLogs"
           class="audit-reset-btn">
            Reset
        </a>
    </form>

    <div class="table-responsive">
        <table class="table audit-table align-middle">
            <thead>
                <tr>
                    <th>Admin</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>Description</th>
                    <th>Date</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Any())
                {
                    foreach (var log in Model)
                    {
                        <tr>
                            <td>
                                <div class="admin-cell">
                                    <div class="admin-avatar">
                                        @((log.Admin?.FullName ?? log.Admin?.Email ?? "A")
                                            .Substring(0, 1)
                                            .ToUpper())
                                    </div>

                                    <div>
                                        <strong>
                                            @(log.Admin?.FullName ?? "Unknown Admin")
                                        </strong>

                                        <span>
                                            @(log.Admin?.Email ?? "No email")
                                        </span>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <span class="action-badge">
                                    @log.Action
                                </span>
                            </td>

                            <td>
                                <div class="entity-cell">
                                    <strong>@log.EntityType</strong>
                                    <span>#@log.EntityId</span>
                                </div>
                            </td>

                            <td>
                                <span class="description-text">
                                    @(string.IsNullOrWhiteSpace(log.Description)
                                        ? "No description"
                                        : log.Description)
                                </span>
                            </td>

                            <td>
                                <span class="date-text">
                                    @log.CreatedAt.ToString("yyyy-MM-dd hh:mm tt")
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5"
                            class="text-center text-muted py-5">
                            No audit logs found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="audit-pagination">
        <a asp-controller="Admin"
           asp-action="AuditLogs"
           asp-route-page="@(currentPage - 1)"
           asp-route-search="@ViewBag.Search"
           asp-route-actionFilter="@ViewBag.ActionFilter"
           asp-route-entityFilter="@ViewBag.EntityFilter"
           asp-route-fromDate="@ViewBag.FromDate"
           asp-route-toDate="@ViewBag.ToDate"
           class="audit-page-btn @(currentPage <= 1 ? "disabled" : "")">
            Previous
        </a>

        <span>
            Page @currentPage of @(totalPages == 0 ? 1 : totalPages)
        </span>

        <a asp-controller="Admin"
           asp-action="AuditLogs"
           asp-route-page="@(currentPage + 1)"
           asp-route-search="@ViewBag.Search"
           asp-route-actionFilter="@ViewBag.ActionFilter"
           asp-route-entityFilter="@ViewBag.EntityFilter"
           asp-route-fromDate="@ViewBag.FromDate"
           asp-route-toDate="@ViewBag.ToDate"
           class="audit-page-btn @(currentPage >= totalPages ? "disabled" : "")">
            Next
        </a>
    </div>

</div>