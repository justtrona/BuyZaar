@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin Dashboard";

    var topSellers = ViewBag.TopSellersMonthly as IEnumerable<dynamic>;
    decimal maxSales = 0;
    decimal totalMonthlySales = 0;
    int totalMonthlyItems = 0;
    string topSellerName = "No seller yet";

    if (topSellers != null && topSellers.Any())
    {
        maxSales = topSellers.Max(s => (decimal)s.TotalSales);
        totalMonthlySales = topSellers.Sum(s => (decimal)s.TotalSales);
        totalMonthlyItems = topSellers.Sum(s => (int)s.TotalItems);
        topSellerName = topSellers.First().SellerName;
    }
}

<div class="admin-dashboard">
    <div class="dashboard-header">
        <div>
            <h1>Admin Dashboard</h1>
            <p>Welcome back, Admin. Here’s what’s happening in BuyZaar today.</p>
        </div>

        <a asp-controller="Admin"
           asp-action="SellerApplications"
           class="header-action-btn">
            Review Applications
        </a>
    </div>

    <div class="stats-grid">
        <div class="stat-card blue">
            <div class="stat-icon">👥</div>
            <div>
                <span>Total Users</span>
                <h2>@ViewBag.TotalUsers</h2>
            </div>
        </div>

        <div class="stat-card green">
            <div class="stat-icon">🏪</div>
            <div>
                <span>Total Sellers</span>
                <h2>@ViewBag.TotalSellers</h2>
            </div>
        </div>

        <div class="stat-card purple">
            <div class="stat-icon">🛵</div>
            <div>
                <span>Total Riders</span>
                <h2>@ViewBag.TotalRiders</h2>
            </div>
        </div>

        <div class="stat-card orange">
            <div class="stat-icon">📝</div>
            <div>
                <span>Pending Applications</span>
                <h2>@ViewBag.PendingSellerApplications</h2>
            </div>
        </div>
    </div>

    <div class="seller-analytics-grid">

        <div class="dashboard-panel top-sellers-panel">
            <div class="panel-header top-sellers-header">
                <div>
                    <h3>Top Sellers This Month</h3>
                    <p>Top 10 sellers ranked by delivered sales.</p>
                </div>

                <a asp-controller="Admin"
                   asp-action="ManageSeller"
                   class="top-sellers-link">
                    View Sellers
                </a>
            </div>

            @if (topSellers != null && topSellers.Any())
            {
                <div class="top-sellers-list">
                    @{
                        var rank = 1;
                    }

                    @foreach (var seller in topSellers)
                    {
                        decimal totalSales = seller.TotalSales;
                        decimal percentage = maxSales > 0 ? (totalSales / maxSales) * 100 : 0;

                        <div class="top-seller-row">
                            <div class="seller-rank">
                                #@rank
                            </div>

                            <div class="seller-chart-info">
                                <div class="seller-chart-header">
                                    <strong>@seller.SellerName</strong>
                                    <span>₱@totalSales.ToString("N2")</span>
                                </div>

                                <div class="seller-bar-track">
                                    <div class="seller-bar-fill"
                                         style="width: @percentage%;">
                                    </div>
                                </div>

                                <small>
                                    @seller.TotalItems item(s) sold this month
                                </small>
                            </div>
                        </div>

                        rank++;
                    }
                </div>
            }
            else
            {
                <div class="empty-top-sellers">
                    No delivered seller sales recorded this month.
                </div>
            }
        </div>

        <div class="dashboard-panel sales-analytics-panel">
            <div class="panel-header">
                <h3>Sales Analytics</h3>
                <p>Monthly sales performance summary.</p>
            </div>

            <div class="sales-kpi-main">
                <span>Total Monthly Sales</span>
                <strong>₱@totalMonthlySales.ToString("N2")</strong>
            </div>

            <div class="sales-kpi-grid">
                <div>
                    <span>Items Sold</span>
                    <strong>@totalMonthlyItems</strong>
                </div>

                <div>
                    <span>Top Seller</span>
                    <strong>@topSellerName</strong>
                </div>

                <div>
                    <span>Ranked Sellers</span>
                    <strong>@(topSellers?.Count() ?? 0)</strong>
                </div>

                <div>
                    <span>Best Sale</span>
                    <strong>₱@maxSales.ToString("N2")</strong>
                </div>
            </div>
        </div>

    </div>

    <div class="dashboard-grid">
        <div class="dashboard-panel">
            <div class="panel-header">
                <h3>Admin Actions</h3>
                <p>Quick access to common management tools.</p>
            </div>

            <div class="action-grid">
                <a asp-controller="Admin" asp-action="SellerApplications" class="action-card">
                    <span>📝</span>
                    <div>
                        <h4>Seller Applications</h4>
                        <p>Approve or reject seller requests</p>
                    </div>
                </a>

                <a asp-controller="Admin" asp-action="Riders" class="action-card">
                    <span>🛵</span>
                    <div>
                        <h4>Manage Riders</h4>
                        <p>View and create rider accounts</p>
                    </div>
                </a>

                <a asp-controller="Admin" asp-action="Orders" class="action-card">
                    <span>📦</span>
                    <div>
                        <h4>Manage Orders</h4>
                        <p>Assign riders and monitor orders</p>
                    </div>
                </a>

                <a asp-controller="Admin" asp-action="CancellationRequests" class="action-card">
                    <span>↩️</span>
                    <div>
                        <h4>Cancellations</h4>
                        <p>Review cancellation requests</p>
                    </div>
                </a>

                <a asp-controller="Admin" asp-action="Users" class="action-card">
                    <span>👤</span>
                    <div>
                        <h4>Manage Users</h4>
                        <p>View shoppers, sellers, and admins</p>
                    </div>
                </a>

                <a asp-controller="Admin" asp-action="Products" class="action-card">
                    <span>🛍️</span>
                    <div>
                        <h4>Manage Products</h4>
                        <p>Monitor seller product listings</p>
                    </div>
                </a>
            </div>
        </div>

        <div class="dashboard-panel side-panel">
            <div class="panel-header">
                <h3>System Overview</h3>
                <p>Important admin monitoring summary.</p>
            </div>

            <div class="overview-list">
                <div>
                    <span>Total Orders</span>
                    <strong>@ViewBag.TotalOrders</strong>
                </div>

                <div>
                    <span>Pending Cancellations</span>
                    <strong>@ViewBag.PendingCancellationRequests</strong>
                </div>

                <div>
                    <span>Return Pending</span>
                    <strong>@ViewBag.ReturnPendingOrders</strong>
                </div>

                <div>
                    <span>Successful Returns</span>
                    <strong>@ViewBag.SuccessfulReturns</strong>
                </div>

                <div>
                    <span>Failed Deliveries</span>
                    <strong>@ViewBag.FailedDeliveries</strong>
                </div>
            </div>
        </div>
    </div>
</div>