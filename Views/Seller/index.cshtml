@{
    Layout = "_DashboardLayout";
    ViewBag.ActiveRole = "Seller";
    ViewData["Title"] = "Seller Dashboard";

    var productCount = ViewBag.ProductCount ?? 0;
    var pendingOrders = ViewBag.PendingOrders ?? 0;
    var lowStock = ViewBag.LowStock ?? 0;

    decimal monthlySales = Convert.ToDecimal(ViewBag.MonthlySales ?? 0);
    decimal releasedSales = Convert.ToDecimal(ViewBag.ReleasedSales ?? 0);
    decimal pendingSettlement = Convert.ToDecimal(ViewBag.PendingSettlement ?? 0);
    decimal totalSalesValue = releasedSales + pendingSettlement;

    var selectedMonth = ViewBag.SelectedMonth ?? DateTime.Now.Month;
    var selectedYear = ViewBag.SelectedYear ?? DateTime.Now.Year;

    string[] salesChartLabels = ViewBag.SalesChartLabels as string[] ?? Array.Empty<string>();
    List<decimal> salesChartData = ViewBag.SalesChartData as List<decimal> ?? new List<decimal>();

    string[] orderStatusLabels = ViewBag.OrderStatusLabels as string[] ?? Array.Empty<string>();
    int[] orderStatusData = ViewBag.OrderStatusData as int[] ?? Array.Empty<int>();

    var hasSalesChartData = salesChartLabels.Any() && salesChartData.Any(x => x > 0);
    var hasOrderChartData = orderStatusLabels.Any() && orderStatusData.Any(x => x > 0);
}

<link rel="stylesheet" href="~/css/sellerdashboard.css" asp-append-version="true" />

<div class="seller-dashboard-page">

    <section class="seller-hero">
        <div class="seller-hero-content">
            <span class="seller-badge">Seller Dashboard</span>

            <h1>Welcome back, @User.Identity?.Name!</h1>

            <p>
                Manage your products, track orders, monitor sales,
                and grow your BuyZaar shop.
            </p>

            <div class="hero-mini-stats">
                <div>
                    <span>Released Sales</span>
                    <strong>₱@releasedSales.ToString("N2")</strong>
                </div>

                <div>
                    <span>Pending Settlement</span>
                    <strong>₱@pendingSettlement.ToString("N2")</strong>
                </div>
            </div>
        </div>

        <div class="seller-hero-actions">
            <a asp-controller="Seller"
               asp-action="CreateProduct"
               class="hero-add-btn">
                + Add Product
            </a>

            <a asp-controller="Seller"
               asp-action="SalesRecords"
               class="hero-secondary-btn">
                View Sales
            </a>
        </div>
    </section>

    <section class="seller-stats-grid">

        <div class="seller-stat-card">
            <div class="stat-icon blue">📦</div>
            <span>Total Products</span>
            <strong>@productCount</strong>
            <p>Active product listings</p>
        </div>

        <div class="seller-stat-card">
            <div class="stat-icon purple">🛒</div>
            <span>Pending Orders</span>
            <strong>@pendingOrders</strong>
            <p>Orders waiting for seller action</p>
        </div>

        <div class="seller-stat-card warning">
            <div class="stat-icon red">⚠️</div>
            <span>Low Stock</span>
            <strong>@lowStock</strong>
            <p>Products needing restock</p>
        </div>

        <div class="seller-stat-card sales-card">
            <div class="stat-icon green">💰</div>
            <span>Sales Value</span>
            <strong>₱@totalSalesValue.ToString("N2")</strong>
            <p>Released + pending settlement</p>
        </div>

    </section>

    <section class="seller-kpi-grid">

        <div class="seller-card kpi-card wide-card">
            <div class="seller-card-header">
                <div>
                    <h2>Sales Trend</h2>
                    <p>Sales performance for the selected month and year.</p>
                </div>

                <form asp-controller="Seller"
                      asp-action="Index"
                      method="get"
                      class="kpi-filter-form">

                    <select name="month" class="kpi-filter-select">
                        <option value="1" selected="@(selectedMonth == 1)">January</option>
                        <option value="2" selected="@(selectedMonth == 2)">February</option>
                        <option value="3" selected="@(selectedMonth == 3)">March</option>
                        <option value="4" selected="@(selectedMonth == 4)">April</option>
                        <option value="5" selected="@(selectedMonth == 5)">May</option>
                        <option value="6" selected="@(selectedMonth == 6)">June</option>
                        <option value="7" selected="@(selectedMonth == 7)">July</option>
                        <option value="8" selected="@(selectedMonth == 8)">August</option>
                        <option value="9" selected="@(selectedMonth == 9)">September</option>
                        <option value="10" selected="@(selectedMonth == 10)">October</option>
                        <option value="11" selected="@(selectedMonth == 11)">November</option>
                        <option value="12" selected="@(selectedMonth == 12)">December</option>
                    </select>

                    <select name="year" class="kpi-filter-select">
                        @for (int y = DateTime.Now.Year + 1; y >= DateTime.Now.Year - 5; y--)
                        {
                            <option value="@y" selected="@(selectedYear == y)">@y</option>
                        }
                    </select>

                    <button type="submit" class="kpi-filter-btn">
                        Apply
                    </button>
                </form>
            </div>

            <div class="chart-wrapper">
                @if (hasSalesChartData)
                {
                    <canvas id="salesChart"></canvas>
                }
                else
                {
                    <div class="chart-empty-state">
                        <strong>No chart data available</strong>
                        <p>Your sales summary exists, but no daily chart points were found for this period.</p>
                    </div>
                }
            </div>
        </div>

        <div class="seller-card kpi-card">
            <div class="seller-card-header">
                <div>
                    <h2>Order Status</h2>
                    <p>Current buyer order distribution.</p>
                </div>
            </div>

            <div class="chart-wrapper doughnut-wrapper">
                @if (hasOrderChartData)
                {
                    <canvas id="ordersChart"></canvas>
                }
                else
                {
                    <div class="chart-empty-state">
                        <strong>No order status data</strong>
                        <p>Order distribution will appear when buyers place orders.</p>
                    </div>
                }
            </div>
        </div>

    </section>

    <section class="seller-content-grid">

        <div class="seller-card">
            <div class="seller-card-header">
                <div>
                    <h2>Quick Actions</h2>
                    <p>Common tasks for managing your shop.</p>
                </div>
            </div>

            <div class="quick-action-grid">

                <a asp-controller="Seller"
                   asp-action="Products"
                   class="quick-action-card">
                    <span>📦</span>
                    <strong>Manage Products</strong>
                    <p>Edit, delete, and view your items.</p>
                </a>

                <a asp-controller="Seller"
                   asp-action="CreateProduct"
                   class="quick-action-card">
                    <span>➕</span>
                    <strong>Add Product</strong>
                    <p>Create a new product listing.</p>
                </a>

                <a asp-controller="Seller"
                   asp-action="Orders"
                   class="quick-action-card">
                    <span>🛒</span>
                    <strong>Orders</strong>
                    <p>View and process buyer orders.</p>
                </a>

                <a asp-controller="Seller"
                   asp-action="SalesRecords"
                   class="quick-action-card">
                    <span>💸</span>
                    <strong>Sales Records</strong>
                    <p>Track released and pending earnings.</p>
                </a>

            </div>
        </div>

        <div class="seller-card recent-card">
            <div class="seller-card-header">
                <div>
                    <h2>Recent Activity</h2>
                    <p>Latest shop reminders.</p>
                </div>
            </div>

            <div class="activity-list">

                <div class="activity-item">
                    <span></span>
                    <div>
                        <strong>Your store is active</strong>
                        <p>You can now manage products and orders.</p>
                    </div>
                </div>

                <div class="activity-item">
                    <span></span>
                    <div>
                        <strong>@pendingOrders pending order(s)</strong>
                        <p>Check your order list for buyer updates.</p>
                    </div>
                </div>

                <div class="activity-item">
                    <span></span>
                    <div>
                        <strong>₱@totalSalesValue.ToString("N2") sales value</strong>
                        <p>Based on released and pending settlement records.</p>
                    </div>
                </div>

            </div>
        </div>

    </section>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        try {
            const salesLabels =
                @Html.Raw(System.Text.Json.JsonSerializer.Serialize<string[]>(salesChartLabels));

            const salesData =
                @Html.Raw(System.Text.Json.JsonSerializer.Serialize<List<decimal>>(salesChartData));

            const orderLabels =
                @Html.Raw(System.Text.Json.JsonSerializer.Serialize<string[]>(orderStatusLabels));

            const orderData =
                @Html.Raw(System.Text.Json.JsonSerializer.Serialize<int[]>(orderStatusData));

            const salesCanvas = document.getElementById("salesChart");

            if (salesCanvas && salesLabels.length > 0 && salesData.some(value => Number(value) > 0)) {
                new Chart(salesCanvas, {
                    type: "line",
                    data: {
                        labels: salesLabels,
                        datasets: [{
                            label: "Sales",
                            data: salesData,
                            borderColor: "#2563eb",
                            backgroundColor: "rgba(37, 99, 235, 0.12)",
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 4,
                            pointHoverRadius: 7
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        return "₱" + Number(context.raw).toLocaleString(undefined, {
                                            minimumFractionDigits: 2,
                                            maximumFractionDigits: 2
                                        });
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: {
                                    display: false
                                }
                            },
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function (value) {
                                        return "₱" + Number(value).toLocaleString();
                                    }
                                }
                            }
                        }
                    }
                });
            }

            const ordersCanvas = document.getElementById("ordersChart");

            if (ordersCanvas && orderLabels.length > 0 && orderData.some(value => value > 0)) {
                new Chart(ordersCanvas, {
                    type: "doughnut",
                    data: {
                        labels: orderLabels,
                        datasets: [{
                            data: orderData,
                            backgroundColor: [
                                "#2563eb",
                                "#7c3aed",
                                "#16a34a",
                                "#f59e0b",
                                "#ef4444"
                            ],
                            borderWidth: 0,
                            hoverOffset: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: "68%",
                        plugins: {
                            legend: {
                                position: "bottom",
                                labels: {
                                    padding: 18,
                                    usePointStyle: true
                                }
                            }
                        }
                    }
                });
            }
        }
        catch (error) {
            console.error("Dashboard chart error:", error);
        }
    </script>
}