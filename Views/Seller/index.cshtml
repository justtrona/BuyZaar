@{
   
    Layout = "_DashboardLayout";
    ViewBag.ActiveRole = "Seller";
    var productCount = ViewBag.ProductCount ?? 0;
}

<div class="dashboard-container">

    <!-- HERO -->
    <div class="dashboard-hero">
        <div>
            <span class="role-badge seller-badge">Seller</span>
            <h1>Welcome back, @User.Identity?.Name!</h1>
            <p>Manage your products, orders, and shop performance from one place.</p>
        </div>

        <a asp-controller="Seller" asp-action="CreateProduct" class="btn btn-primary hero-btn">
            Add Product
        </a>
    </div>

    <!-- STATS -->
    <div class="stats-grid">
        <div class="stat-card">
            <p>Total Products</p>
            <h2>@productCount</h2>
        </div>

        <div class="stat-card">
            <p>Pending Orders</p>
            <h2>0</h2>
        </div>

        <div class="stat-card">
            <p>Low Stock</p>
            <h2>0</h2>
        </div>

        <div class="stat-card">
            <p>Monthly Sales</p>
            <h2>₱0</h2>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="content-grid">
        <div class="dashboard-card">
            <h4>Quick Actions</h4>

            <div class="action-grid">
                <a asp-controller="Seller" asp-action="Products" class="action-card">
                    <h5>Manage Products</h5>
                </a>

                <a href="#" class="action-card">
                    <h5>Orders</h5>
                </a>

                <a href="#" class="action-card">
                    <h5>Shop Profile</h5>
                </a>
            </div>
        </div>

        <div class="dashboard-card">
            <h4>Recent Activity</h4>
            <ul>
                <li>Your store is ready.</li>
                <li>You can now add products.</li>
            </ul>
        </div>
    </div>
</div>