@model List<BuyZaar.Models.Order>

@{
    Layout = "_DashboardLayout";
    ViewBag.ActiveRole = "Seller";
    ViewData["Title"] = "Sales Records";

    decimal totalSales = ViewBag.TotalSales ?? 0;
    decimal pendingSales = ViewBag.PendingSales ?? 0;
    decimal reportTotal = totalSales;

    int totalOrders = ViewBag.TotalOrders ?? 0;
    int totalItemsSold = ViewBag.TotalItemsSold ?? 0;

    string currentStatus = ViewBag.Status ?? "";
    string search = ViewBag.Search ?? "";
    string fromDate = ViewBag.FromDate ?? "";
    string toDate = ViewBag.ToDate ?? "";

    var generatedDate = DateTime.Now;
}

<link rel="stylesheet" href="~/css/salesrecords.css" asp-append-version="true" />

<div class="sales-records-page">

    <div class="sales-header">
        <div>
            <span class="seller-label">Seller</span>
            <h1>Sales Records</h1>
            <p>Track sales performance based on customer orders.</p>
        </div>
    </div>

    <div class="sales-actions">
        <button type="button"
                class="btn-print-sales"
                onclick="printSalesReport()">
            <i class="fa-solid fa-print"></i>
            Print Sales Report
        </button>
    </div>

    <div class="sales-stats-grid">
        <div class="sales-stat-card">
            <span>Total Sales</span>
            <strong>₱@totalSales.ToString("N2")</strong>
        </div>

        <div class="sales-stat-card">
            <span>Pending Sales</span>
            <strong>₱@pendingSales.ToString("N2")</strong>
        </div>

        <div class="sales-stat-card">
            <span>Total Orders</span>
            <strong>@totalOrders</strong>
        </div>

        <div class="sales-stat-card">
            <span>Items Sold</span>
            <strong>@totalItemsSold</strong>
        </div>
    </div>

    <form asp-controller="Seller"
          asp-action="SalesRecords"
          method="get"
          class="sales-filter-card">

        <input type="text"
               name="search"
               value="@search"
               placeholder="Search order ID, buyer name, or contact..."
               class="sales-search" />

        <select name="status" class="sales-select">
            <option value="">All Status</option>
            <option value="To Ship" selected="@(currentStatus == "To Ship")">To Ship</option>
            <option value="To Receive" selected="@(currentStatus == "To Receive")">To Receive</option>
            <option value="To Review" selected="@(currentStatus == "To Review")">To Review</option>
            <option value="Completed" selected="@(currentStatus == "Completed")">Completed</option>
            <option value="Cancelled" selected="@(currentStatus == "Cancelled")">Cancelled</option>
        </select>

        <input type="date" name="fromDate" value="@fromDate" class="sales-date" />
        <input type="date" name="toDate" value="@toDate" class="sales-date" />

        <button type="submit" class="btn-sales-filter">Filter</button>

        <a asp-controller="Seller"
           asp-action="SalesRecords"
           class="btn-sales-reset">
            Reset
        </a>
    </form>

    @if (!Model.Any())
    {
        <div class="empty-sales">
            <h3>No sales records found</h3>
            <p>Sales records will appear once buyers place orders.</p>
        </div>
    }
    else
    {
        <div class="sales-table-card">
            <div class="sales-table-header">
                <strong>Order</strong>
                <strong>Buyer</strong>
                <strong>Products</strong>
                <strong>Items</strong>
                <strong>Sales</strong>
                <strong>Status</strong>
                <strong>Date</strong>
            </div>

            @foreach (var order in Model)
            {
                var sellerItems = order.OrderItems.ToList();
                var firstItem = sellerItems.FirstOrDefault();
                var firstProduct = firstItem?.Product;
                var image = firstProduct?.Images?.FirstOrDefault()?.ImagePath ?? "/images/no-image.png";
                var sellerSubtotal = sellerItems.Sum(i => i.Subtotal);
                var itemCount = sellerItems.Sum(i => i.Quantity);
                var isEarned = order.Status == "Completed";

                <div class="sales-table-row">
                    <div class="sales-order-cell">
                        <img src="@Url.Content(image)" alt="Product" />

                        <div>
                            <strong>Order #@order.Id</strong>
                            <span>BZ-@order.Id-@order.CreatedAt.ToString("yyMMddHHmm")</span>
                        </div>
                    </div>

                    <div>
                        <strong>@order.ReceiverName</strong>
                        <span>@order.ContactNumber</span>
                    </div>

                    <div>
                        <strong>@(firstProduct?.Name ?? "Product")</strong>
                        <span>@sellerItems.Count product line(s)</span>
                    </div>

                    <div>
                        <strong>@itemCount</strong>
                        <span>item(s)</span>
                    </div>

                    <div class="sales-amount @(isEarned ? "earned" : "pending")">
                        @if (isEarned)
                        {
                            <span>₱@sellerSubtotal.ToString("N2")</span>
                        }
                        else
                        {
                            <span>PENDING</span>
                        }
                    </div>

                    <div>
                        <span class="sales-status">@order.Status</span>
                    </div>

                    <div>
                        <strong>@order.CreatedAt.ToString("MMM dd, yyyy")</strong>
                        <span>@order.CreatedAt.ToString("hh:mm tt")</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div id="printSalesReport" class="print-sales-report">
    <div class="print-report-container">

        <div class="print-report-header">
            <div class="print-brand">
                <h1>BuyZaar</h1>
                <p>Seller Sales Performance Report</p>
            </div>

            <div class="print-report-meta">
                <h2>Sales Report</h2>
                <span>Generated: @generatedDate.ToString("MMM dd, yyyy hh:mm tt")</span>
                <span>Status: @(string.IsNullOrWhiteSpace(currentStatus) ? "All Status" : currentStatus)</span>
                <span>Period: @(string.IsNullOrWhiteSpace(fromDate) ? "Start" : fromDate) - @(string.IsNullOrWhiteSpace(toDate) ? "Present" : toDate)</span>
            </div>
        </div>

        <div class="print-report-info">
            <div>
                <span>Report Type</span>
                <strong>Seller Sales Report</strong>
            </div>

            <div>
                <span>Total Orders</span>
                <strong>@totalOrders</strong>
            </div>

            <div>
                <span>Total Items Sold</span>
                <strong>@totalItemsSold</strong>
            </div>
        </div>

        <table class="print-sales-table">
            <thead>
                <tr>
                    <th>Reference No.</th>
                    <th>Buyer</th>
                    <th>Product</th>
                    <th>Items</th>
                    <th>Status</th>
                    <th>Sales Status</th>
                    <th>Date</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var order in Model)
                {
                    var sellerItems = order.OrderItems.ToList();
                    var firstProduct = sellerItems.FirstOrDefault()?.Product;
                    var sellerSubtotal = sellerItems.Sum(i => i.Subtotal);
                    var itemCount = sellerItems.Sum(i => i.Quantity);
                    var isEarned = order.Status == "Completed";
                    var referenceNo = $"BZ-{order.Id}-{order.CreatedAt:yyMMddHHmm}";

                    <tr>
                        <td>
                            <strong>@referenceNo</strong>
                            <span>Order #@order.Id</span>
                        </td>

                        <td>
                            <strong>@order.ReceiverName</strong>
                            <span>@order.ContactNumber</span>
                        </td>

                        <td>
                            <strong>@(firstProduct?.Name ?? "Product")</strong>
                            <span>@sellerItems.Count product line(s)</span>
                        </td>

                        <td>@itemCount</td>

                        <td>
                            <span class="print-status">@order.Status</span>
                        </td>

                        <td>
                            @if (isEarned)
                            {
                                <strong class="print-earned">Earned</strong>
                                <span>₱@sellerSubtotal.ToString("N2")</span>
                            }
                            else
                            {
                                <strong class="print-pending">Not Yet Earned</strong>
                                <span>Pending delivery/completion</span>
                            }
                        </td>

                        <td>
                            <strong>@order.CreatedAt.ToString("MMM dd, yyyy")</strong>
                            <span>@order.CreatedAt.ToString("hh:mm tt")</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="print-total-section">
            <div class="print-total-box">
                <div>
                    <span>Total Earned Sales</span>
                    <strong class="earned-total">₱@totalSales.ToString("N2")</strong>
                </div>

                <div>
                    <span>Pending Sales / Not Yet Earned</span>
                    <strong class="pending-total">₱@pendingSales.ToString("N2")</strong>
                </div>

                <div class="grand-total">
                    <span>Net Earned Revenue</span>
                    <strong>₱@reportTotal.ToString("N2")</strong>
                </div>
            </div>
        </div>

        <div class="print-report-footer">
            <div class="print-footer-note">
                This report is system-generated by BuyZaar. Pending sales are not included in net earned revenue until the order is completed.
            </div>

            <div class="print-signature">
                <div class="print-signature-line"></div>
                <span>Prepared by Seller</span>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function printSalesReport() {
            const report = document.getElementById("printSalesReport");
            const printWindow = window.open("", "_blank", "width=1000,height=800");

            printWindow.document.write(`
                <!DOCTYPE html>
                <html>
                <head>
                    <title>BuyZaar Sales Report</title>

                    <style>
                        * {
                            box-sizing: border-box;
                        }

                        body {
                            margin: 0;
                            padding: 35px;
                            font-family: Arial, sans-serif;
                            color: #111827;
                            background: #ffffff;
                        }

                        .print-report-container {
                            width: 100%;
                        }

                        .print-report-header {
                            display: flex;
                            justify-content: space-between;
                            align-items: flex-start;
                            border-bottom: 3px solid #111827;
                            padding-bottom: 18px;
                            margin-bottom: 22px;
                        }

                        .print-brand h1 {
                            margin: 0;
                            font-size: 40px;
                            font-weight: 900;
                            letter-spacing: -1px;
                        }

                        .print-brand p {
                            margin: 6px 0 0;
                            color: #475569;
                            font-size: 14px;
                        }

                        .print-report-meta {
                            text-align: right;
                        }

                        .print-report-meta h2 {
                            margin: 0 0 10px;
                            font-size: 28px;
                            font-weight: 900;
                        }

                        .print-report-meta span {
                            display: block;
                            color: #475569;
                            font-size: 12px;
                            margin-bottom: 4px;
                        }

                        .print-report-info {
                            display: grid;
                            grid-template-columns: 2fr 1fr 1fr;
                            gap: 12px;
                            margin-bottom: 22px;
                        }

                        .print-report-info div {
                            border: 1px solid #d1d5db;
                            border-radius: 12px;
                            padding: 14px;
                            background: #f8fafc;
                        }

                        .print-report-info span,
                        .print-total-box span {
                            display: block;
                            color: #64748b;
                            font-size: 12px;
                            margin-bottom: 6px;
                        }

                        .print-report-info strong {
                            font-size: 18px;
                            font-weight: 900;
                        }

                        .print-sales-table {
                            width: 100%;
                            border-collapse: collapse;
                            margin-bottom: 24px;
                        }

                        .print-sales-table th {
                            background: #111827;
                            color: #ffffff;
                            padding: 11px;
                            text-align: left;
                            font-size: 12px;
                        }

                        .print-sales-table td {
                            border: 1px solid #d1d5db;
                            padding: 11px;
                            vertical-align: top;
                            font-size: 12px;
                        }

                        .print-sales-table td strong {
                            display: block;
                            font-size: 13px;
                            margin-bottom: 3px;
                        }

                        .print-sales-table td span {
                            display: block;
                            color: #64748b;
                            font-size: 11px;
                        }

                        .print-status {
                            display: inline-block !important;
                            width: fit-content;
                            padding: 5px 10px;
                            border-radius: 999px;
                            background: #dbeafe;
                            color: #1d4ed8 !important;
                            font-weight: 900;
                            font-size: 11px !important;
                        }

                        .print-earned,
                        .earned-total {
                            color: #16a34a;
                            font-weight: 900;
                        }

                        .print-pending,
                        .pending-total {
                            color: #d97706;
                            font-weight: 900;
                        }

                        .print-total-section {
                            display: flex;
                            justify-content: flex-end;
                            margin-top: 8px;
                        }

                        .print-total-box {
                            width: 390px;
                            border: 1px solid #d1d5db;
                            border-radius: 14px;
                            overflow: hidden;
                            background: #ffffff;
                        }

                        .print-total-box div {
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            padding: 14px 18px;
                            border-bottom: 1px solid #e5e7eb;
                            gap: 20px;
                        }

                        .print-total-box div:last-child {
                            border-bottom: none;
                        }

                        .print-total-box strong {
                            font-size: 17px;
                            font-weight: 900;
                            white-space: nowrap;
                        }

                        .print-total-box .grand-total {
                            background: #111827;
                            color: #ffffff;
                        }

                        .print-total-box .grand-total span {
                            color: #e5e7eb;
                        }

                        .print-total-box .grand-total strong {
                            color: #ffffff;
                            font-size: 22px;
                        }

                        .print-report-footer {
                            margin-top: 50px;
                            display: flex;
                            justify-content: space-between;
                            align-items: flex-end;
                            gap: 40px;
                        }

                        .print-footer-note {
                            max-width: 460px;
                            color: #64748b;
                            font-size: 12px;
                            line-height: 1.6;
                        }

                        .print-signature {
                            width: 240px;
                            text-align: center;
                        }

                        .print-signature-line {
                            border-top: 2px solid #111827;
                            margin-bottom: 8px;
                        }

                        .print-signature span {
                            font-size: 12px;
                            font-weight: 700;
                        }

                        @@media print {
                            body {
                                padding: 20px;
                            }
                        }
                    </style>
                </head>

                <body>
                    ${report.innerHTML}
                </body>
                </html>
            `);

            printWindow.document.close();

            setTimeout(() => {
                printWindow.focus();
                printWindow.print();
            }, 500);
        }
    </script>
}