@model BuyZaar.ViewModels.ProductViewModel

@{
    Layout = "_DashboardLayout";
    ViewBag.ActiveRole = "Seller";
    ViewData["Title"] = "Edit Product";
}

<link rel="stylesheet" href="~/css/product.css" asp-append-version="true" />

<div class="product-page-shell">

    <div class="product-page-header">
        <div class="header-left">
            <span class="role-badge seller-badge">Seller</span>
            <h1>Edit Product</h1>
            <p>Update your product listing details.</p>
        </div>

        <div class="header-right">
            <a asp-controller="Seller" asp-action="Products" class="btn btn-light back-btn">
                Back to Products
            </a>
        </div>
    </div>

    <div class="product-form-card">
        <div class="form-card-header">
            <h3>Product Information</h3>
            <p>Edit the details below and manage your product images.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger custom-alert"></div>
        }

        <form asp-action="EditProduct" method="post" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />
            <input type="hidden" name="productId" value="@Model.Id" />

            <div class="product-form-grid">

                <div class="form-group full-width">
                    <label asp-for="Name" class="form-label">Product Name</label>
                    <input asp-for="Name" class="form-control custom-input" placeholder="Enter product name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="form-group full-width">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description"
                              class="form-control custom-input custom-textarea"
                              rows="5"
                              placeholder="Describe your product"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="form-group full-width">
                    <label asp-for="Category" class="form-label">Category</label>
                    <input asp-for="Category"
                           class="form-control custom-input"
                           placeholder="e.g. Electronics, Clothing, Accessories" />
                    <span asp-validation-for="Category" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Price" class="form-label">Price (₱)</label>
                    <input asp-for="Price"
                           class="form-control custom-input"
                           type="number"
                           step="0.01"
                           placeholder="0.00" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Stock" class="form-label">Stock</label>
                    <input asp-for="Stock"
                           class="form-control custom-input"
                           type="number"
                           placeholder="0" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>

                @if (Model.ExistingImages != null && Model.ExistingImages.Any())
                {
                    <div class="form-group full-width">
                        <label class="form-label">Current Images</label>

                        <div class="existing-images-grid">
                            @foreach (var image in Model.ExistingImages)
                            {
                                <div class="existing-image-item">
                                    <img src="@image" class="existing-product-img" alt="Product image" />

                                    <button type="submit"
                                            formaction="@Url.Action("DeleteProductImage", "Seller")"
                                            formmethod="post"
                                            name="imagePath"
                                            value="@image"
                                            class="delete-image-btn"
                                            onclick="return confirm('Delete this image?')">
                                        ×
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="form-group full-width">
                    <label asp-for="ProductImages" class="form-label">Add More Product Images</label>
                    <input asp-for="ProductImages"
                           class="form-control custom-input"
                           type="file"
                           multiple
                           accept="image/*" />
                    <span asp-validation-for="ProductImages" class="text-danger small"></span>
                    <small class="text-muted">
                        You can upload additional images. Allowed: JPG, JPEG, PNG, WEBP.
                    </small>
                </div>

            </div>

            <div class="form-divider"></div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary save-btn">
                    Update Product
                </button>

                <a asp-controller="Seller" asp-action="Products" class="btn btn-outline-secondary cancel-btn">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}