@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "BuyZaar";
}

<section class="hero-section text-center py-5">
    <div class="container">
        <h1 class="display-4">Discover Deals, Explore Styles – Only at BuyZaar</h1>
        <p>Guaranteed to boost your mood, shop the latest trends now!</p>
        <a href="#categories" class="btn btn-primary btn-lg">Shop Now</a>
    </div>
</section>

<section id="categories" class="categories-section py-5">
    <div class="container">
        <h2 class="text-center mb-4">Shop by Categories</h2>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="category-card text-center">
                    <div class="category-card-images">
                        <img src="~/images/woman-clothes.jpg" alt="Women Clothes" class="img-fluid" />
                        <img src="~/images/women-handbag.jpg" alt="Women Handbag" class="img-fluid" />
                        <img src="~/images/women-sandals.jpg" alt="Women Sandals" class="img-fluid" />
                    </div>

                    <h3>Women</h3>
                    <a href="#" class="btn btn-primary">Shop Women</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="category-card text-center">
                    <div class="category-card-images">
                        <img src="~/images/men-clothes.jpg" alt="Men Clothes" class="img-fluid" />
                        <img src="~/images/men-watch.jpg" alt="Men Watch" class="img-fluid" />
                        <img src="~/images/men-shoes.jpg" alt="Men Shoes" class="img-fluid" />
                    </div>

                    <h3>Men</h3>
                    <a href="#" class="btn btn-primary">Shop Men</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="category-card text-center">
                    <div class="category-card-images">
                        <img src="~/images/laptop-electronics.jpg" alt="Laptop Electronics" class="img-fluid" />
                        <img src="~/images/headphones-electronics.jpg" alt="Headphones Electronics" class="img-fluid" />
                        <img src="~/images/iphone-electronics.jpg" alt="Smartphone Electronics" class="img-fluid" />
                    </div>

                    <h3>Electronics</h3>
                    <a href="#" class="btn btn-primary">Shop Electronics</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="featured-products py-5">
    <div class="container text-center">
        <h2 class="mb-4">Featured Products</h2>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="product-card">
                    <img src="~/images/product1.jpg" alt="Product 1" class="img-fluid" />
                    <h4>Product Name</h4>
                    <p>₱99.99</p>
                    <a href="#" class="btn btn-primary">Add to Cart</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="product-card">
                    <img src="~/images/product2.jpg" alt="Product 2" class="img-fluid" />
                    <h4>Product Name</h4>
                    <p>₱99.99</p>
                    <a href="#" class="btn btn-primary">Add to Cart</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="product-card">
                    <img src="~/images/product3.jpg" alt="Product 3" class="img-fluid" />
                    <h4>Product Name</h4>
                    <p>₱99.99</p>
                    <a href="#" class="btn btn-primary">Add to Cart</a>
                </div>
            </div>
        </div>
    </div>
</section>