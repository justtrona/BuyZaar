@{
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
    ViewData["Title"] = "SuperAdmin Dashboard";

    var totalUsers = ViewBag.TotalUsers ?? 0;
    var totalShoppers = ViewBag.TotalShoppers ?? 0;
    var totalSellers = ViewBag.TotalSellers ?? 0;
    var totalRiders = ViewBag.TotalRiders ?? 0;
    var totalAdmins = ViewBag.TotalAdmins ?? 0;

    var totalProducts = ViewBag.TotalProducts ?? 0;
    var visibleProducts = ViewBag.VisibleProducts ?? 0;
    var hiddenProducts = ViewBag.HiddenProducts ?? 0;
    var lowStockProducts = ViewBag.LowStockProducts ?? 0;
    var outOfStockProducts = ViewBag.OutOfStockProducts ?? 0;

    var completedOrders = ViewBag.CompletedOrders ?? 0;
    var pendingOrders = ViewBag.PendingOrders ?? 0;
    var cancelledOrders = ViewBag.CancelledOrders ?? 0;

    var totalPayments = ViewBag.TotalPayments ?? 0;
    var totalDeliveries = ViewBag.TotalDeliveries ?? 0;
}

<div class="superadmin-page">

    <div class="superadmin-hero">
        <div>
            <h1>SuperAdmin Dashboard</h1>
            <p>Monitor BuyZaar users, products, orders, payments, deliveries, and platform operations.</p>
        </div>

        <span class="superadmin-badge">
            SuperAdmin
        </span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success superadmin-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="dashboard-kpi-grid">
        <div class="dashboard-kpi-card">
            <span>Total Users</span>
            <strong>@totalUsers</strong>
            <p>All registered accounts</p>
        </div>

        <div class="dashboard-kpi-card">
            <span>Sellers</span>
            <strong>@totalSellers</strong>
            <p>Approved seller accounts</p>
        </div>

        <div class="dashboard-kpi-card">
            <span>Riders</span>
            <strong>@totalRiders</strong>
            <p>Delivery personnel</p>
        </div>

        <div class="dashboard-kpi-card">
            <span>Products</span>
            <strong>@totalProducts</strong>
            <p>Marketplace listings</p>
        </div>
    </div>

    <div class="dashboard-analytics-grid">

        <div class="dashboard-chart-card">
            <div class="chart-card-header">
                <div>
                    <h3>User Distribution</h3>
                    <p>Breakdown of shoppers, sellers, riders, and admins.</p>
                </div>
            </div>

            <canvas id="userDistributionChart"></canvas>
        </div>

        <div class="dashboard-chart-card">
            <div class="chart-card-header">
                <div>
                    <h3>Order Overview</h3>
                    <p>Pending, completed, cancelled, payment, and delivery records.</p>
                </div>
            </div>

            <canvas id="orderOverviewChart"></canvas>
        </div>

    </div>

    <div class="dashboard-section-grid">

        <div class="dashboard-panel">
            <div class="dashboard-panel-header">
                <h3>Product Monitoring</h3>
                <p>Marketplace product visibility and inventory health.</p>
            </div>

            <div class="summary-list">
                <div>
                    <span>Visible Products</span>
                    <strong>@visibleProducts</strong>
                </div>

                <div>
                    <span>Hidden Products</span>
                    <strong>@hiddenProducts</strong>
                </div>

                <div>
                    <span>Low Stock Products</span>
                    <strong>@lowStockProducts</strong>
                </div>

                <div>
                    <span>Out of Stock</span>
                    <strong>@outOfStockProducts</strong>
                </div>
            </div>
        </div>

        <div class="dashboard-panel">
            <div class="dashboard-panel-header">
                <h3>Quick Actions</h3>
                <p>Access SuperAdmin controls.</p>
            </div>

            <div class="superadmin-action-grid">
                <a asp-controller="SuperAdmin" asp-action="CreateAdmin" class="superadmin-action-card">
                    <strong>Create Admin</strong>
                    <span>Add operational admin</span>
                </a>

                <a asp-controller="SuperAdmin" asp-action="Admins" class="superadmin-action-card">
                    <strong>Manage Admins</strong>
                    <span>Activate or deactivate admins</span>
                </a>

                <a asp-controller="SuperAdmin" asp-action="Users" class="superadmin-action-card">
                    <strong>Manage Users</strong>
                    <span>Monitor platform users</span>
                </a>

                <a asp-controller="SuperAdmin" asp-action="Sellers" class="superadmin-action-card">
                    <strong>Manage Sellers</strong>
                    <span>Monitor seller accounts</span>
                </a>

                <a asp-controller="SuperAdmin" asp-action="Riders" class="superadmin-action-card">
                    <strong>View Riders</strong>
                    <span>Monitor delivery personnel</span>
                </a>

                <a asp-controller="SuperAdmin" asp-action="Products" class="superadmin-action-card">
                    <strong>Products</strong>
                    <span>Review product listings</span>
                </a>

                <a asp-controller="SuperAdmin" asp-action="Orders" class="superadmin-action-card">
                    <strong>Orders</strong>
                    <span>Track order activity</span>
                </a>

                <a asp-controller="SuperAdmin" asp-action="AuditLogs" class="superadmin-action-card">
                    <strong>Audit Logs</strong>
                    <span>Review system actions</span>
                </a>
            </div>
        </div>

    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        new Chart(document.getElementById("userDistributionChart"), {
            type: "doughnut",
            data: {
                labels: ["Shoppers", "Sellers", "Riders", "Admins"],
                datasets: [{
                    data: [
                        @totalShoppers,
                        @totalSellers,
                        @totalRiders,
                        @totalAdmins
                    ],
                    backgroundColor: [
                        "#2563eb",
                        "#16a34a",
                        "#f59e0b",
                        "#7c3aed"
                    ],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: "65%",
                plugins: {
                    legend: {
                        position: "bottom"
                    }
                }
            }
        });

        new Chart(document.getElementById("orderOverviewChart"), {
            type: "bar",
            data: {
                labels: ["Pending", "Completed", "Cancelled", "Payments", "Deliveries"],
                datasets: [{
                    label: "Total Records",
                    data: [
                        @pendingOrders,
                        @completedOrders,
                        @cancelledOrders,
                        @totalPayments,
                        @totalDeliveries
                    ],
                    backgroundColor: "#2563eb",
                    borderRadius: 10,
                    barThickness: 45
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });
    </script>
}